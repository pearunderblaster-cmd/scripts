-- All _prev* start as a sentinel (empty table) so first-tick comparison always fires,
-- regardless of what loadConfig() set in STATE. This ensures saved-on features activate
-- immediately without needing a retoggle.
local _UNSET = {}

local _RT = {
    autoKillActive = false,
    lastAutoKillShoot = 0,
    prevSkybox = _UNSET,
    prevSkyboxPreset = _UNSET,
    prevFireRateEnabled = _UNSET,
    prevFireRate = _UNSET,
    fastApplied = false,
    prevWalkSpeedEnabled = _UNSET,
    prevJumpPowerEnabled = _UNSET,
    prevNoclip = false,
    noclipAccum = 0,
    origFOV = Camera.FieldOfView,
    prevCameraFOVEnabled = _UNSET,
    prevMapVisuals = _UNSET,
    prevMapPreset = _UNSET,
    prevHighSat = _UNSET,
    highSatCC = nil,
    prevStream = _UNSET,
    streamPatched = {},
    streamConns = {},
    prevMapColorEnabled = _UNSET, -- stores sig string covering all map overlay settings
    arenaOrigColors = {},
    arenaColorConn = nil,
}

local function enableStreaming()
    local name  = LocalPlayer.Name
    local disp  = LocalPlayer.DisplayName
    local function patch(obj)
        if not (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) then return end
        local alias = STATE.StreamingAlias ~= "" and STATE.StreamingAlias or "Streamer"
        local txt = obj.Text; if txt == "" then return end
        local new = txt:gsub(name, alias)
        if disp ~= name then new = new:gsub(disp, alias) end
        if new ~= txt then
            _RT.streamPatched[obj] = _RT.streamPatched[obj] or txt
            pcall(function() obj.Text = new end)
        end
    end
    local function scanChar(char)
        if not char then return end
        for _, obj in ipairs(char:GetDescendants()) do patch(obj) end
        char.DescendantAdded:Connect(patch)
    end
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if pg then
        for _, obj in ipairs(pg:GetDescendants()) do patch(obj) end
        _RT.streamConns[1] = pg.DescendantAdded:Connect(patch)
    end
    for _, p in ipairs(Players:GetPlayers()) do scanChar(p.Character) end
    _RT.streamConns[2] = Players.PlayerAdded:Connect(function(p)
        p.CharacterAdded:Connect(function(char) task.wait(); scanChar(char) end)
    end)
    for _, p in ipairs(Players:GetPlayers()) do
        _RT.streamConns[#_RT.streamConns + 1] = p.CharacterAdded:Connect(function(char)
            task.wait(); scanChar(char)
        end)
    end
end

local function disableStreaming()
    for _, c in ipairs(_RT.streamConns) do pcall(function() c:Disconnect() end) end
    _RT.streamConns = {}
    for obj, txt in pairs(_RT.streamPatched) do
        pcall(function() if obj and obj.Parent then obj.Text = txt end end)
    end
    _RT.streamPatched = {}
end

local _queueAccum = 0

RunService.Heartbeat:Connect(function(dt)
    if not STATE.Master then return end

    _queueAccum = _queueAccum + dt
    if _queueAccum >= 0.3 then
        _queueAccum = 0
        updateQueue()
    end

    if STATE.Teleport and targetPlayer and targetPlayer.Character and LocalPlayer.Character then
        local tRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local lRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if tRoot and lRoot then
            pcall(function() lRoot.CFrame = CFrame.new(tRoot.Position + Vector3.new(0, TP_HEIGHT, 0)) end)
        end
    end

    _trajAccum = _trajAccum + dt
    if _trajAccum >= TRAJ_INTERVAL then
        _trajAccum = _trajAccum % TRAJ_INTERVAL
        if STATE.AimTrajectory then
            for player, data in pairs(TRAJ_DATA) do
                if player == LocalPlayer or not isEnemy(player) then continue end
                local char = getCharacter(player)
                local root = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head"))
                if root then
                    local pts = data.points
                    pts[#pts + 1] = root.Position
                    while #pts > TRAJ_MAX_PTS do table.remove(pts, 1) end
                end
            end
        end
    end
end)

local function isMapModel(obj)
    return obj:IsA("Model") and obj:FindFirstChild("Spectate") and obj:FindFirstChild("Primary")
end

local function findParentMapModel(obj)
    local cur = obj.Parent
    while cur and cur ~= workspace do
        if isMapModel(cur) then return cur end
        cur = cur.Parent
    end
end

local function getMapColor()
    return Color3.fromRGB(STATE.MapColorR, STATE.MapColorG, STATE.MapColorB)
end

-- ─── Map Dome ────────────────────────────────────────────────────────────────

local DOME_WALL_TAG  = "RBDomeWall"
local _domeWalls     = {}
local _coloredModels = {}  -- [model] = true, tracks which models already have dome+color applied

local DOME_MATERIALS = {
    "Neon","SmoothPlastic","Glass","ForceField","Metal",
    "Wood","Marble","Granite","Fabric","Ice",
}
local DOME_MATERIAL_MAP = {}
for _, name in ipairs(DOME_MATERIALS) do
    DOME_MATERIAL_MAP[name] = Enum.Material[name]
end

local function getDomeColor()
    return Color3.fromRGB(STATE.MapDomeColorR, STATE.MapDomeColorG, STATE.MapDomeColorB)
end

local function spawnDomeWallsForModel(model)
    local color        = getDomeColor()
    local mat          = DOME_MATERIAL_MAP[STATE.MapDomeMaterial] or Enum.Material.Neon
    local transparency = STATE.MapDomeTransparency / 100
    local SIZE = Vector3.new(400, 400, 6)
    local DIST = 200
    local cf   = model:GetPivot()
    local transforms = {
        cf * CFrame.new(0,    0,    DIST),
        cf * CFrame.new(0,    0,   -DIST),
        cf * CFrame.new(DIST,  0,   0) * CFrame.Angles(0, math.rad(90), 0),
        cf * CFrame.new(-DIST, 0,   0) * CFrame.Angles(0, math.rad(90), 0),
        cf * CFrame.new(0,    DIST, 0) * CFrame.Angles(math.rad(90), 0, 0),
    }
    for _, wallCF in ipairs(transforms) do
        local wall = Instance.new("Part")
        wall.Name         = DOME_WALL_TAG
        wall.Size         = SIZE
        wall.Color        = color
        wall.Material     = mat
        wall.Anchored     = true
        wall.CanCollide   = false
        wall.CastShadow   = false
        wall.Transparency = transparency
        wall.CFrame       = wallCF
        wall.Parent       = workspace
        _domeWalls[#_domeWalls + 1] = wall
    end
end

local function colorModelParts(model)
    local newColor = getMapColor()
    for _, part in ipairs(model:GetDescendants()) do
        if part:IsA("BasePart") then
            if not _RT.arenaOrigColors[part] then _RT.arenaOrigColors[part] = part.Color end
            pcall(function() part.Color = newColor end)
        end
    end
end

-- Apply color and/or dome to a single qualifying model we haven't processed yet.
local function applyToModel(model)
    if _coloredModels[model] then return end
    _coloredModels[model] = true
    if STATE.MapColorEnabled then colorModelParts(model) end
    if STATE.MapDome        then spawnDomeWallsForModel(model) end
end

-- Scan all existing workspace descendants for qualifying models.
local function scanWorkspace()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if isMapModel(obj) then applyToModel(obj) end
    end
end

local function clearDomeWalls()
    for _, w in ipairs(_domeWalls) do pcall(function() w:Destroy() end) end
    _domeWalls = {}
end

local function disableArenaColor()
    if _RT.arenaColorConn then _RT.arenaColorConn:Disconnect(); _RT.arenaColorConn = nil end
    for part, origColor in pairs(_RT.arenaOrigColors) do
        pcall(function() part.Color = origColor end)
    end
    _RT.arenaOrigColors = {}
end



-- Full teardown: restores original colors, destroys dome walls, clears tracking.
local function teardownMapOverlays()
    disableArenaColor()
    clearDomeWalls()
    _coloredModels = {}
end

-- Re-applies everything from scratch (called when settings change while enabled).
local function rebuildMapOverlays()
    teardownMapOverlays()
    scanWorkspace()
end

-- Called once to wire up the DescendantAdded watcher for late-streaming models.
local function startMapWatcher()
    if _RT.arenaColorConn then _RT.arenaColorConn:Disconnect() end
    _RT.arenaColorConn = workspace.DescendantAdded:Connect(function(obj)
        if not (STATE.MapColorEnabled or STATE.MapDome or STATE.RainbowMap) then return end
        -- A newly added Model won't have its children yet; defer one frame so
        -- isMapModel (which checks for Spectate + Primary children) can succeed.
        if obj:IsA("Model") then
            task.defer(function()
                if obj.Parent and isMapModel(obj) then applyToModel(obj) end
            end)
        elseif obj:IsA("BasePart") then
            -- Part added inside an already-qualified model that we haven't seen yet
            task.defer(function()
                local model = findParentMapModel(obj)
                if model then applyToModel(model) end
            end)
        end
    end)
end

local function stopMapWatcher()
    if _RT.arenaColorConn then _RT.arenaColorConn:Disconnect(); _RT.arenaColorConn = nil end
end

RunService.Stepped:Connect(function(_, dt)
    Camera = workspace.CurrentCamera

    -- ── State-change detection runs unconditionally (not gated by Master) ──
    -- This ensures features saved as enabled in config activate on first tick,
    -- and toggling a feature while Master is off still takes effect.

    if STATE.FireRateEnabled ~= _RT.prevFireRateEnabled or STATE.FireRate ~= _RT.prevFireRate then
        _RT.prevFireRateEnabled = STATE.FireRateEnabled; _RT.prevFireRate = STATE.FireRate
        _RT.fastApplied = false
        if not STATE.FireRateEnabled then restoreItemLibrary() end
    end

    if STATE.WalkSpeedEnabled ~= _RT.prevWalkSpeedEnabled then
        _RT.prevWalkSpeedEnabled = STATE.WalkSpeedEnabled
        if not STATE.WalkSpeedEnabled and LocalPlayer.Character then
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = origHumStats.WalkSpeed end
        end
    end
    if STATE.JumpPowerEnabled ~= _RT.prevJumpPowerEnabled then
        _RT.prevJumpPowerEnabled = STATE.JumpPowerEnabled
        if not STATE.JumpPowerEnabled and LocalPlayer.Character then
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.JumpPower = origHumStats.JumpPower end
        end
    end

    if STATE.CameraFOVEnabled ~= _RT.prevCameraFOVEnabled then
        _RT.prevCameraFOVEnabled = STATE.CameraFOVEnabled
        if not STATE.CameraFOVEnabled then
            Camera.FieldOfView = _RT.origFOV
        end
    end

    local wantMV = STATE.MapVisuals
    local presetChanged = STATE.MapVisualsPreset ~= _RT.prevMapPreset
    _RT.prevMapPreset = STATE.MapVisualsPreset
    if wantMV ~= _RT.prevMapVisuals then
        _RT.prevMapVisuals = wantMV
        if wantMV then _mapVisualsApplied = true; pcall(MAP_PRESETS[STATE.MapVisualsPreset] or function() end)
        else restoreMapVisuals() end
    elseif wantMV and presetChanged then
        restoreMapVisuals(); _mapVisualsApplied = true
        pcall(MAP_PRESETS[STATE.MapVisualsPreset] or function() end)
    end

    if STATE.HighSaturation ~= _RT.prevHighSat then
        _RT.prevHighSat = STATE.HighSaturation
        if STATE.HighSaturation then
            if not _RT.highSatCC then
                _RT.highSatCC = Instance.new("ColorCorrectionEffect", Lighting)
                _RT.highSatCC.Name = "HighSatCC"
            end
            _RT.highSatCC.Saturation = 1.8
        else
            if _RT.highSatCC then _RT.highSatCC:Destroy(); _RT.highSatCC = nil end
        end
    end

    -- Compute a sig covering all map overlay settings.
    -- Any change (toggle, color, material, transparency) triggers a full rebuild.
    local anyOverlay = STATE.MapColorEnabled or STATE.MapDome or STATE.RainbowMap
    local sig = tostring(anyOverlay)
        .. tostring(STATE.MapColorEnabled) .. tostring(STATE.MapColorR) .. tostring(STATE.MapColorG) .. tostring(STATE.MapColorB)
        .. tostring(STATE.MapDome) .. tostring(STATE.MapDomeMaterial)
        .. tostring(STATE.MapDomeColorR) .. tostring(STATE.MapDomeColorG) .. tostring(STATE.MapDomeColorB)
        .. tostring(STATE.MapDomeTransparency)
        .. tostring(STATE.RainbowMap)

    if sig ~= _RT.prevMapColorEnabled then
        _RT.prevMapColorEnabled = sig
        if anyOverlay then
            rebuildMapOverlays()
            startMapWatcher()
        else
            teardownMapOverlays()
            stopMapWatcher()
        end
    end

    if STATE.StreamingMode ~= _RT.prevStream then
        _RT.prevStream = STATE.StreamingMode
        if STATE.StreamingMode then enableStreaming() else disableStreaming() end
    end


    -- Skybox changer
    local wantSkybox = STATE.SkyboxEnabled and STATE.Master
    if wantSkybox ~= _RT.prevSkybox or (wantSkybox and STATE.SkyboxPreset ~= _RT.prevSkyboxPreset) then
        _RT.prevSkybox = wantSkybox; _RT.prevSkyboxPreset = STATE.SkyboxPreset
        if wantSkybox then
            local sky = Lighting:FindFirstChild("RageByteSky") or Instance.new("Sky")
            sky.Name = "RageByteSky"; sky.Parent = Lighting
            local preset = SKYBOX_PRESETS[STATE.SkyboxPreset]
            if preset then
                for k, v in pairs(preset) do sky[k] = v end
            end
        else
            local sky = Lighting:FindFirstChild("RageByteSky")
            if sky then sky:Destroy() end
        end
    end

    -- ── Per-frame active work — gated by Master ──
    if not STATE.Master then return end

    if STATE.FireRateEnabled and not _RT.fastApplied and type(ItemLibrary) == "table" then
        applyFastWeapons(); _RT.fastApplied = true
    end

    if STATE.WalkSpeedEnabled and LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = STATE.WalkSpeed end
    end

    if STATE.NoRecoil and LocalPlayer.Character then
        local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool then
            local rv = tool:FindFirstChild("Recoil", true)
            if rv then pcall(function() rv.Value = 0 end) end
        end
    end

    local wantNoclip = STATE.Noclip
    if wantNoclip then
        _RT.noclipAccum = _RT.noclipAccum + dt
        if _RT.noclipAccum >= 0.15 then
            _RT.noclipAccum = 0
            local char = LocalPlayer.Character
            if char then
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end
    elseif _RT.prevNoclip then
        local char = LocalPlayer.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then pcall(function() part.CanCollide = true end) end
            end
        end
    end
    _RT.prevNoclip = wantNoclip
end)

RunService.RenderStepped:Connect(function(dt)
    if STATE.RainbowVisuals or STATE.RainbowMap then _rbColor = getRainbow(0) end

    if STATE.RainbowMap then
        -- drive arena parts
        if STATE.MapColorEnabled then
            for part in pairs(_RT.arenaOrigColors) do
                pcall(function() part.Color = _rbColor end)
            end
        end
        -- drive dome walls
        if STATE.MapDome then
            local mat = DOME_MATERIAL_MAP[STATE.MapDomeMaterial] or Enum.Material.Neon
            local transp = STATE.MapDomeTransparency / 100
            for _, w in ipairs(_domeWalls) do
                pcall(function() w.Color = _rbColor; w.Material = mat; w.Transparency = transp end)
            end
        end
    end

    if FOVCircle then
        FOVCircle.Radius   = STATE.AimFOV
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        FOVCircle.Color    = STATE.RainbowVisuals and _rbColor or Color3.fromRGB(200,200,200)
        FOVCircle.Visible  = STATE.Aimbot and STATE.Master
    end

    if STATE.Aimbot and STATE.AimActive and STATE.Master then
        local t = getClosestInFOV(); if t then aimAt(t) end
    end
    -- AutoKill (desync-based)
    if STATE.AutoKill and STATE.Master then
        local akTarget = getLowestHealthTarget()
        if akTarget and akTarget.Character then
            local akHum = akTarget.Character:FindFirstChild("Humanoid")
            if akHum and akHum.Health > 0 then
                _ds:__desync_start(akTarget)
                if not _RT.autoKillActive then _RT.autoKillActive = true end
                local now = tick()
                if now - _RT.lastAutoKillShoot > math.max(STATE.FireRate, 0.05) then
                    _RT.lastAutoKillShoot = now
                    if performClick then task.spawn(performClick) end
                end
            else
                _ds:__desync_stop()
                _RT.autoKillActive = false
            end
        else
            _ds:__desync_stop()
            _RT.autoKillActive = false
        end
    elseif _RT.autoKillActive then
        _ds:__desync_stop()
        _RT.autoKillActive = false
        if Camera.CameraType == Enum.CameraType.Scriptable then
            Camera.CameraType = Enum.CameraType.Custom
            if LocalPlayer.Character then
                local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if hum then Camera.CameraSubject = hum end
            end
        end
    end



    if STATE.Master then runTriggerbot() end

    if STATE.CameraFOVEnabled then
        Camera.FieldOfView = STATE.CameraFOV
    end

    if TargetLineDrawing then
        if STATE.TargetLine and STATE.Master then
            local lineTarget = STATE.SilentAim and getSilentAimTarget()
                or (STATE.Aimbot and getClosestInFOV())
            if lineTarget then
                local char = getCharacter(lineTarget)
                local part = char and (char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart"))
                if part then
                    local sp, onScreen, depth = worldToScreen(part.Position)
                    if onScreen and depth > 0 and getDistance(lineTarget) <= 400 then
                        TargetLineDrawing.From    = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
                        TargetLineDrawing.To      = sp
                        TargetLineDrawing.Color   = STATE.RainbowVisuals and _rbColor or Color3.fromRGB(STATE.TargetLineColorR, STATE.TargetLineColorG, STATE.TargetLineColorB)
                        TargetLineDrawing.Visible = true
                    else
                        TargetLineDrawing.Visible = false
                    end
                else
                    TargetLineDrawing.Visible = false
                end
            else
                TargetLineDrawing.Visible = false
            end
        else
            TargetLineDrawing.Visible = false
        end
    end

    if Drawing then
        for player, _ in pairs(ESP_OBJECTS) do updateESP(player) end
    end

    do
        local chamsActive = STATE.ChamsESP and STATE.Master
        local chamsColor  = visualColor(STATE.ChamsR, STATE.ChamsG, STATE.ChamsB)
        for player, data in pairs(CHAMS_OBJECTS) do
            if data.hl and data.hl.Parent then
                local char   = player.Character
                local hum    = char and char:FindFirstChildOfClass("Humanoid")
                data.hl.Enabled   = chamsActive and isEnemy(player) and hum ~= nil and hum.Health > 0
                data.hl.FillColor = chamsColor
            end
        end
    end

    do
        local trajColor = visualColor(STATE.AimTrajR, STATE.AimTrajG, STATE.AimTrajB)
        local lineIdx   = 0
        if STATE.AimTrajectory and STATE.Master then
            for player, data in pairs(TRAJ_DATA) do
                if not isEnemy(player) then continue end
                local pts = data.points
                local n   = #pts
                if n < 4 then continue end
                local sp = {}
                for i, wp in ipairs(pts) do
                    local s, _, depth = worldToScreen(wp)
                    sp[i] = depth > 0 and s or false
                end
                for i = 2, n - 2 do
                    local p0, p1, p2, p3 = sp[i-1], sp[i], sp[i+1], sp[i+2]
                    if not (p0 and p1 and p2 and p3) then continue end
                    local transp = 1 - ((i-1)/(n-1)) * 0.97
                    for s = 0, TRAJ_SUBSEG - 1 do
                        if lineIdx >= TRAJ_MAX_LINES then break end
                        lineIdx = lineIdx + 1
                        local ln = getTrajLine(lineIdx)
                        if ln then
                            ln.From = catmullV2(p0,p1,p2,p3, s/TRAJ_SUBSEG)
                            ln.To   = catmullV2(p0,p1,p2,p3, (s+1)/TRAJ_SUBSEG)
                            ln.Color = trajColor; ln.Transparency = transp; ln.Visible = true
                        end
                    end
                end
            end
        end
        for i = lineIdx + 1, TRAJ_LINES_USED do
            if TRAJ_LINE_POOL[i] then TRAJ_LINE_POOL[i].Visible = false end
        end
        TRAJ_LINES_USED = lineIdx
    end

    if _chImg then
        local want = STATE.CrosshairEnabled and STATE.Master
        if want then
            local style = STATE.CrosshairStyle or "emoji"
            if style ~= _chStyle or STATE.CrosshairSize ~= _chSize then applyCrosshair() end
            if STATE.CrosshairSpin then
                _crosshairAngle = (_crosshairAngle + SPIN_SPEED * dt) % 360
            else
                _crosshairAngle = 0
            end
            _chImg.Rotation = _crosshairAngle
            _chImg.Visible  = true
        else
            _chImg.Visible = false
        end
    end

    updateFly()
end)

