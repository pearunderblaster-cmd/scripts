local function loadConfig()
    if not (readfile and isfile) or not isfile(CONFIG_FILE) then return end
    local ok, raw = pcall(readfile, CONFIG_FILE)
    if not ok then return end
    local ok2, parsed = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok2 or type(parsed) ~= "table" then return end
    for _, k in ipairs(SAVEABLE_KEYS) do
        if parsed[k] ~= nil then STATE[k] = parsed[k] end
    end
end

