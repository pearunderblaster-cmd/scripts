-- ─── Fly ─────────────────────────────────────────────────────────────────────

local _flyCleanedUp = true

local function updateFly()
    local want = STATE.Fly and STATE.Master
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChildOfClass("Humanoid")

    if not want then
        if not _flyCleanedUp and root then
            local bv = root:FindFirstChild("_RR_FlyBV")
            local bg = root:FindFirstChild("_RR_FlyBG")
            if bv then bv:Destroy() end
            if bg then bg:Destroy() end
        end
        if hum and hum.PlatformStand then hum.PlatformStand = false end
        _flyCleanedUp = true
        return
    end
    if not root or not hum then return end
    _flyCleanedUp = false
    hum.PlatformStand = true

    local bv = root:FindFirstChild("_RR_FlyBV")
    if not bv then
        bv = Instance.new("BodyVelocity"); bv.Name = "_RR_FlyBV"
        bv.MaxForce = Vector3.new(1e5,1e5,1e5); bv.Velocity = Vector3.zero
        bv.Parent = root
    end
    local bg = root:FindFirstChild("_RR_FlyBG")
    if not bg then
        bg = Instance.new("BodyGyro"); bg.Name = "_RR_FlyBG"
        bg.MaxTorque = Vector3.new(1e5,1e5,1e5); bg.D = 100; bg.P = 1e4
        bg.Parent = root
    end

    local camCF = Camera.CFrame
    local dir   = Vector3.zero
    local uis   = UserInputService
    if uis:IsKeyDown(Enum.KeyCode.W)         then dir = dir + camCF.LookVector end
    if uis:IsKeyDown(Enum.KeyCode.S)         then dir = dir - camCF.LookVector end
    if uis:IsKeyDown(Enum.KeyCode.A)         then dir = dir - camCF.RightVector end
    if uis:IsKeyDown(Enum.KeyCode.D)         then dir = dir + camCF.RightVector end
    if uis:IsKeyDown(Enum.KeyCode.Space)     then dir = dir + Vector3.yAxis end
    if uis:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.yAxis end
    bv.Velocity = dir.Magnitude > 0 and (dir.Unit * 50) or Vector3.zero
    bg.CFrame   = camCF
end

-- ─── Teleport Queue ──────────────────────────────────────────────────────────

local playerQueue, targetPlayer, currentIndex = {}, nil, 1

local function updateQueue()
    playerQueue = {}
    local lChar = LocalPlayer.Character
    local lRoot = lChar and lChar:FindFirstChild("HumanoidRootPart")
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hum  = p.Character:FindFirstChild("Humanoid")
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if hum and root and hum.Health > 0 and lRoot
                and (root.Position - lRoot.Position).Magnitude <= MAX_STUD_DISTANCE then
                playerQueue[#playerQueue + 1] = p
            end
        end
    end
    if currentIndex > #playerQueue or #playerQueue == 0 then currentIndex = 1 end
    targetPlayer = playerQueue[currentIndex]
end

