local function cloneBeam(beam)
    if not STATE.BulletTracers or not STATE.Master then return end
    if beam:GetAttribute("IsClone") or not beam.Attachment0 or not beam.Attachment1 then return end
    local att0, att1 = beam.Attachment0:Clone(), beam.Attachment1:Clone()
    att0.Parent = workspace.Terrain; att1.Parent = workspace.Terrain
    local clone = beam:Clone()
    clone:SetAttribute("IsClone", true)
    clone.Color = ColorSequence.new(Color3.fromRGB(STATE.TracerR, STATE.TracerG, STATE.TracerB))
    clone.LightEmission = 0; clone.Transparency = NumberSequence.new(0.4)
    clone.Attachment0 = att0; clone.Attachment1 = att1; clone.Parent = workspace
    Debris:AddItem(clone, 2); Debris:AddItem(att0, 2); Debris:AddItem(att1, 2)
end

local function cloneImpact(original)
    if not STATE.ImpactMarkers or not STATE.Master then return end
    local clone = original:Clone()
    pcall(function()
        local color = Color3.fromRGB(STATE.ImpactR, STATE.ImpactG, STATE.ImpactB)
        if clone:IsA("BasePart") then clone.Color = color end
        for _, v in ipairs(clone:GetDescendants()) do
            if v:IsA("BasePart") then v.Color = color
            elseif v:IsA("Beam") then v.Color = ColorSequence.new(color)
            elseif v:IsA("ParticleEmitter") then v.Color = ColorSequence.new(color) end
        end
    end)
    clone:SetAttribute("IsClone", true); clone.Parent = workspace
    task.delay(2, function() pcall(function() clone:Destroy() end) end)
end

local function processBulletObj(obj)
    if obj:IsA("Beam") then
        pcall(cloneBeam, obj)
    elseif obj.Name == "ImpactMarkerBullet" and not obj:GetAttribute("IsClone") then
        pcall(cloneImpact, obj)
    end
end

