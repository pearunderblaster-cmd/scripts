-- ─── Menu Toggle Keybind ────────────────────────────────────────
-- Obsidian's built-in ToggleKeybind only fires for KeyPicker objects, not a raw
-- KeyCode, so we drive the toggle ourselves. Default is "K"; type any
-- Enum.KeyCode name (K, RightShift, F, Insert, ...) into the textbox to rebind.
do
    local UIMenu = Tabs.UI:AddLeftGroupbox("Menu")
    local menuKeyInput
    local settingKey = false
    menuKeyInput = UIMenu:AddInput("MenuToggleKey", {
        Default = STATE.MenuToggleKey,
        Text = "Menu Toggle Key",
        Finished = true,
        Placeholder = "e.g. K",
        Callback = function(value)
            if settingKey then return end
            local cleaned = tostring(value):gsub("%s+", "")
            local matched
            for _, kc in ipairs(Enum.KeyCode:GetEnumItems()) do
                if kc.Name:lower() == cleaned:lower() then
                    matched = kc.Name
                    break
                end
            end
            settingKey = true
            if matched then
                STATE.MenuToggleKey = matched
                saveConfig()
                if menuKeyInput then menuKeyInput:SetValue(matched) end
                notify("Menu toggle key set to: " .. matched)
            else
                if menuKeyInput then menuKeyInput:SetValue(STATE.MenuToggleKey) end
                notify("Invalid key '" .. tostring(value) .. "' - kept " .. STATE.MenuToggleKey)
            end
            settingKey = false
        end,
    })
    UIMenu:AddButton("Unload Script", stopScript)

    Library:GiveSignal(UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe or Library.Unloaded then return end
        if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
        if UserInputService:GetFocusedTextBox() then return end
        local keyName = STATE.MenuToggleKey
        if not keyName or keyName == "" then return end
        local ok, keyCode = pcall(function() return Enum.KeyCode[keyName] end)
        if ok and keyCode and input.KeyCode == keyCode then
            Library:Toggle()
        end
    end))
end

