local function aimAt(target, bypassSmooth)
    local char = getCharacter(target)
    if not char then return end

    local part = char:FindFirstChild(STATE.AimPart)
    if STATE.AimPart == "Head" then
        part = char:FindFirstChild("HitboxHeadSmall") or part
    end
    if not part then part = char:FindFirstChild("Head") end
    if not part then return end

    if STATE.AimMethod == "Camera" then
        local cameraPos = Camera.CFrame.Position
        local targetPos = part.Position
        local targetCFrame = CFrame.new(cameraPos, targetPos)
        local smoothFactor = bypassSmooth and 0 or (math.clamp(STATE.AimSmoothness, 1, 20) / 20)
        local lerpFactor = 1 - smoothFactor
        if lerpFactor < 0.05 and not bypassSmooth then lerpFactor = 0.05 end
        local smoothedCFrame = Camera.CFrame:Lerp(targetCFrame, lerpFactor)

        pcall(function()
            local CameraController = require(LocalPlayer.PlayerScripts.Controllers.CameraController)
            CameraController.Rotation = Vector2.new(smoothedCFrame:ToEulerAnglesYXZ())
            local Utility = require(ReplicatedStorage.Modules.Utility)
            local encoded = Utility:EncodeCameraRotation(CameraController.Rotation)
            ReplicatedStorage.Remotes.Replication.Fighter.UpdateCameraRotation:FireServer(encoded, nil)
        end)
    else
        local screenPos, onScreen = worldToScreen(part.Position)
        if not onScreen and not bypassSmooth then return end
        local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        local smooth = bypassSmooth and 1 or math.max(STATE.AimSmoothness * 0.1, 0.05)
        local move   = (screenPos - center) / smooth
        if STATE.AimHumanize and not bypassSmooth then move = move + Vector2.new(math.random(-2, 2), math.random(-2, 2)) end
        if performCameraMove then performCameraMove(math.floor(move.X), math.floor(move.Y))
        elseif mousemoverel then mousemoverel(math.floor(move.X), math.floor(move.Y)) end
    end
end

