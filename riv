local _cachedPlayerDataController = nil
local _lastRiskyNotif = 0
local function getInfoStats()
    local uses, hits, crits = 0, 0, 0
    pcall(function()
        if not _cachedPlayerDataController then
            local Controllers = LocalPlayer.PlayerScripts:FindFirstChild("Controllers")
            if Controllers then
                local pdcModule = Controllers:FindFirstChild("PlayerDataController")
                if pdcModule then
                    _cachedPlayerDataController = require(pdcModule)
                end
            end
        end
        local PDC = _cachedPlayerDataController
        if PDC and type(PDC.Get) == "function" then
            local success = pcall(function()
                uses = PDC:Get("StatisticUses") or 0
                hits = PDC:Get("StatisticUsesHits") or 0
                crits = PDC:Get("StatisticUsesCriticalHits") or 0
            end)
            if not success and PDC.GetAll then
                local data = PDC:GetAll()
                if data then
                    uses = data.StatisticUses or 0
                    hits = data.StatisticUsesHits or 0
                    crits = data.StatisticUsesCriticalHits or 0
                end
            end
        end
    end)
    return uses, hits, crits
end

local function formatPercent(value, total)
    if total == 0 then return "0%" end
    local pct = (value / total) * 100
    if pct >= 100 then return "100%" end
    return string.format("%.1f%%", pct)
end

