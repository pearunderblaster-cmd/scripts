local function performCameraMove(dx, dy)
    if mousemoverel then
        mousemoverel(dx, dy)
    else
        local cam = workspace.CurrentCamera
        local fovX = math.rad(cam.FieldOfView)
        local rotY = -(dx / cam.ViewportSize.X) * fovX
        local rotX = -(dy / cam.ViewportSize.X) * fovX
        local cx, cy, cz = cam.CFrame:ToEulerAnglesYXZ()
        local newX = math.clamp(cx + rotX, -math.rad(89), math.rad(89))
        local newY = cy + rotY
        cam.CFrame = CFrame.new(cam.CFrame.Position) * CFrame.Angles(0, newY, 0) * CFrame.Angles(newX, 0, 0)
    end
end

