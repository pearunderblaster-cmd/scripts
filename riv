            args[3][utf8.char(0)] = encode and UtilityModule:EncodeCFrame(originCF)   or originCF
            args[3][utf8.char(1)] = encode and UtilityModule:EncodeCFrame(impactCF)   or impactCF
            args[3][utf8.char(2)] = head
            args[3][utf8.char(3)] = encode and UtilityModule:EncodeCFrame(localHitCF) or localHitCF
        end
        return unpack(args)
    end
end)

