local _dynamicQueueModes = {"1v1", "2v2", "3v3", "4v4", "5v5", "1v1v1", "2v2v2"}
pcall(function()
    local tempDl = require(ReplicatedStorage.Modules.DuelLibrary)
    if tempDl and tempDl.MatchmakingQueues then
        local names = {}
        for qName, _ in pairs(tempDl.MatchmakingQueues) do
            table.insert(names, qName)
        end
        local function getPriority(name)
            local ln = string.lower(name)
            if ln:sub(1, 4) == "ltm_" then return 3 end
            if ln:find("ranked") then return 2 end
            return 1
        end
        table.sort(names, function(a, b)
            local p1 = getPriority(a)
            local p2 = getPriority(b)
            if p1 == p2 then return a < b end
            return p1 < p2
        end)
        if #names > 0 then _dynamicQueueModes = names end
    end
end)

