-- ─── Auto Play Hook ────────────────────────────────────────────────────────

local PathfindingService = game:GetService("PathfindingService")
local _AP = {
    lastCompute = 0,
    path = nil,
    wpIdx = 0,
    target = nil,
    lastShot = 0,
    lastJump = 0,
    lastLeaveCheck = 0,
}

local function performClick()
    if mouse1click then
        mouse1click()
    elseif mouse1press then
        mouse1press()
        task.wait(0.01)
        if mouse1release then mouse1release() end
    else
        local vim = game:GetService("VirtualInputManager")
        local cam = workspace.CurrentCamera
        vim:SendMouseButtonEvent(cam.ViewportSize.X/2, cam.ViewportSize.Y/2, 0, true, game, 1)
        task.wait(0.01)
        vim:SendMouseButtonEvent(cam.ViewportSize.X/2, cam.ViewportSize.Y/2, 0, false, game, 1)
    end
end

local function performCameraMove(dx, dy)
    if mousemoverel then
        mousemoverel(dx, dy)
    else
        local cam = workspace.CurrentCamera
        local fovX = math.rad(cam.FieldOfView)
        local rotY = -(dx / cam.ViewportSize.X) * fovX
        local rotX = -(dy / cam.ViewportSize.X) * fovX
        
        local cx, cy, cz = cam.CFrame:ToEulerAnglesYXZ()
        local newX = math.clamp(cx + rotX, -math.rad(89), math.rad(89))
        local newY = cy + rotY
        
        cam.CFrame = CFrame.new(cam.CFrame.Position) * CFrame.Angles(0, newY, 0) * CFrame.Angles(newX, 0, 0)
    end
end

local function getAutoPlayTarget()
    local closest, dist = nil, math.huge
    local lpChar = LocalPlayer.Character
    if not lpChar then return nil end
    local lpRoot = lpChar:FindFirstChild("HumanoidRootPart")
    if not lpRoot then return nil end
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer or not isAlive(p) or not isEnemy(p) then continue end
        local tChar = p.Character
        local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
        if tRoot then
            local d = (tRoot.Position - lpRoot.Position).Magnitude
            if d < dist and d <= 350 then
                dist = d; closest = p
            end
        end
    end
    return closest
end

local function isVisibleObj(origin, targetPos, ignore)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = ignore
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.IgnoreWater = true
    local res = workspace:Raycast(origin, targetPos - origin, params)
    return res == nil
end

local function canTriggerHit(tChar)
    local char = LocalPlayer.Character
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {char}
    params.FilterType = Enum.RaycastFilterType.Exclude
    local res = workspace:Raycast(Camera.CFrame.Position, Camera.CFrame.LookVector * 500, params)
    return res and res.Instance and res.Instance:IsDescendantOf(tChar)
end

RunService.RenderStepped:Connect(function()
    if not STATE.AutoPlay or not STATE.Master then return end

    local char = LocalPlayer.Character
    if not char then return end

    if tick() - _AP.lastLeaveCheck > 1 then
        _AP.lastLeaveCheck = tick()
        pcall(function()
            local pg = LocalPlayer:FindFirstChild("PlayerGui")
            if pg then
                local di = pg:FindFirstChild("MainGui") and pg.MainGui:FindFirstChild("MainFrame") and pg.MainGui.MainFrame:FindFirstChild("DuelInterfaces")
                if di then
                    for _, child in ipairs(di:GetChildren()) do
                        local fr = child:FindFirstChild("FinalResults")
                        if fr and fr.Visible then
                            local leaveBtn = fr.Buttons.BottomRight.Container:FindFirstChild("Leave")
                            if leaveBtn and leaveBtn.Visible then
                                task.spawn(function()
                                    for i = 1, 3 do
                                        if getconnections then
                                            for _, c in ipairs(getconnections(leaveBtn.MouseButton1Click)) do pcall(function() c:Fire() end) end
                                            for _, c in ipairs(getconnections(leaveBtn.Activated)) do pcall(function() c:Fire() end) end
                                        else
                                            local vim = game:GetService("VirtualInputManager")
                                            local x = leaveBtn.AbsolutePosition.X + (leaveBtn.AbsoluteSize.X / 2)
                                            local y = leaveBtn.AbsolutePosition.Y + (leaveBtn.AbsoluteSize.Y / 2) + 36
                                            vim:SendMouseButtonEvent(x, y, 0, true, game, 1)
                                            task.wait(0.05)
                                            vim:SendMouseButtonEvent(x, y, 0, false, game, 1)
                                        end
                                        task.wait(0.2)
                                    end
                                end)
                            end
                        end
                    end
                end
            end
        end)
    end

    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not root or not hum or hum.Health <= 0 then return end

    local inLobby = false
    pcall(function()
        local spawn = workspace.Lobby.Hub.Important.Center.Spawn
        if (root.Position - spawn.Position).Magnitude <= 125 then
            inLobby = true
        end
    end)
    if inLobby then return end

    _AP.target = getAutoPlayTarget()
    if not _AP.target then 
        return 
    end
    
    local tChar = _AP.target.Character
    if not tChar then return end
    local tRoot = tChar:FindFirstChild("HumanoidRootPart")
    local tHead = tChar:FindFirstChild("Head") or tRoot
    if not tRoot then return end
    
    local isVis = isVisibleObj(Camera.CFrame.Position, tHead.Position, {char, tChar})
    
    -- Pathfinding Polling
    if tick() - _AP.lastCompute > 0.3 then
        _AP.lastCompute = tick()
        task.spawn(function()
            local path = PathfindingService:CreatePath({
                AgentRadius = 2, AgentHeight = 5, AgentCanJump = true
            })
            local targetPos = tRoot.Position
            local params = RaycastParams.new()
            params.FilterType = Enum.RaycastFilterType.Exclude
            params.FilterDescendantsInstances = {char, tChar}
            local floorRay = workspace:Raycast(targetPos, Vector3.new(0, -50, 0), params)
            if floorRay then targetPos = floorRay.Position end
            
            local toUs = (root.Position - targetPos)
            local flatToUs = Vector3.new(toUs.X, 0, toUs.Z)
            if flatToUs.Magnitude > 0 then
                targetPos = targetPos + flatToUs.Unit * 8
            end
            
            local s = pcall(function()
                path:ComputeAsync(root.Position, targetPos)
            end)
            if s and path.Status == Enum.PathStatus.Success then
                _AP.path = path:GetWaypoints()
                local newIdx = 2
                while _AP.path[newIdx] do
                    local dist = (Vector3.new(_AP.path[newIdx].Position.X, 0, _AP.path[newIdx].Position.Z) - Vector3.new(root.Position.X, 0, root.Position.Z)).Magnitude
                    if dist > 3 then break end
                    newIdx = newIdx + 1
                end
                _AP.wpIdx = newIdx
            end
        end)
    end
    
    local moveTarget = tRoot.Position
    local hasWaypoint = false
    local activeMoveDir = nil

    local enemyDist = (tRoot.Position - root.Position).Magnitude
    local apSpeedMult = (STATE.AutoPlaySpeed or 65) / 100
    if isVis and enemyDist < 12 then
        if enemyDist < 8 then
            local dirAway = Vector3.new(root.Position.X - tRoot.Position.X, 0, root.Position.Z - tRoot.Position.Z)
            if dirAway.Magnitude > 0 then
                activeMoveDir = dirAway.Unit
                hum:Move(activeMoveDir * apSpeedMult, false)
            else
                hum:Move(Vector3.zero, false)
            end
        else
            hum:Move(Vector3.zero, false)
        end
    else
        if _AP.path and _AP.path[_AP.wpIdx] then
            hasWaypoint = true
            local wp = _AP.path[_AP.wpIdx]
            moveTarget = wp.Position
            
            local dist2D = Vector2.new(root.Position.X - moveTarget.X, root.Position.Z - moveTarget.Z).Magnitude
            if dist2D < 3 then
                _AP.wpIdx = _AP.wpIdx + 1
            end
            if wp.Action == Enum.PathWaypointAction.Jump then
                hum.Jump = true
            end
        end
        
        local walkSpeed = math.clamp(STATE.WalkSpeedEnabled and STATE.WalkSpeed or 16, 0, 20)
        local slowdownMult = (walkSpeed > 16 and (16 / walkSpeed) or 1) * apSpeedMult
        
        local dir = Vector3.new(moveTarget.X - root.Position.X, 0, moveTarget.Z - root.Position.Z)
        if dir.Magnitude > 0 then
            activeMoveDir = dir.Unit
            hum:Move(activeMoveDir * slowdownMult, false)
            if hum.FloorMaterial ~= Enum.Material.Air then
                if root.Velocity.Magnitude < 2 and tick() - _AP.lastJump > 0.5 then
                    hum.Jump = true
                    _AP.lastJump = tick()
                elseif math.random() < 0.12 and tick() - _AP.lastJump > 0.8 then
                    hum.Jump = true
                    _AP.lastJump = tick()
                end
            end
        else
            hum:Move(Vector3.zero, false)
        end
    end

    local lookTarget = nil

    if isVis then
        lookTarget = tHead.Position
        if canTriggerHit(tChar) and tick() - _AP.lastShot > 0.05 then
            _AP.lastShot = tick()
            task.spawn(performClick)
        end
    elseif activeMoveDir then
        lookTarget = Camera.CFrame.Position + activeMoveDir * 100
    end

    if lookTarget then
        local screenPos, onScreen = Camera:WorldToViewportPoint(lookTarget)
        local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        if onScreen then
            local moveX = screenPos.X - center.X
            local moveY = isVis and (screenPos.Y - center.Y) or 0
            
            local smoothVal = isVis and (STATE.AutoPlayAimSmoothness * 0.1) or (STATE.AutoPlayPathSmoothness * 0.1)
            local move = Vector2.new(moveX, moveY) / math.max(smoothVal, 0.05)

            if isVis and STATE.AimHumanize then move = move + Vector2.new(math.random(-2, 2), math.random(-2, 2)) end
            performCameraMove(math.floor(move.X), math.floor(move.Y))
        else
            local camCFrame = Camera.CFrame
            local targetDir = (lookTarget - camCFrame.Position).Unit
            local right = camCFrame.RightVector
            local mult = right:Dot(targetDir) > 0 and 1 or -1

            local turnSpeed = isVis and (25 / math.max(STATE.AutoPlayAimSmoothness * 0.1, 0.5)) or (25 / math.max(STATE.AutoPlayPathSmoothness * 0.1, 0.5))
            performCameraMove(math.floor(mult * turnSpeed), 0)
        end
    end
end)

