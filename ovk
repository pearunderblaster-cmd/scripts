local function hideAll(obj)
    obj.Box.Visible       = false
    obj.BoxOutline.Visible= false
    obj.BoxFill.Visible   = false
    obj.Tracer.Visible    = false
    obj.Name.Visible      = false
    obj.DistText.Visible  = false
    obj.HealthBG.Visible  = false
    obj.HeadDot.Visible   = false
    if obj.Highlight then obj.Highlight.Enabled = false end
    for _, ln in ipairs(obj.CornerLines) do ln.Visible = false end
    for _, ln in ipairs(obj.HealthSegs)  do ln.Visible = false end
    for _, ln in ipairs(obj.Skeleton)    do ln.Visible = false end
    for _, ln in ipairs(obj.GradLines)   do ln.Visible = false end
end

local function removeESP(char)
    local obj = ESP_OBJECTS[char]
    if not obj then return end
    for _, v in pairs(obj) do
        if type(v) == "table" then
            for _, ln in ipairs(v) do pcall(function() ln:Remove() end) end
        else
            pcall(function() v:Remove() end)
            pcall(function() v:Destroy() end)
        end
    end
    ESP_OBJECTS[char] = nil
    ESP_PLAYER_MAP[char] = nil
    PREVIOUS_ENEMY_HEALTH[char] = nil
end

local function updateESP(char)
    local obj = ESP_OBJECTS[char]
    if not obj then return end

    local hum  = char:FindFirstChildOfClass("Humanoid")
    local hrp  = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso") or char.PrimaryPart
    
    local active = STATE.ESP and hrp

    if not active then hideAll(obj); return end

    local hrpPos, onScreen, depth = worldToScreen(hrp.Position)
    local dist = getDistance(char)

    if not onScreen or depth <= 0 or dist > STATE.ESPMaxDistance then hideAll(obj); return end

    local topScreen  = worldToScreen(hrp.Position + Vector3.new(0, 3.1, 0))
    local footScreen = worldToScreen(hrp.Position - Vector3.new(0, 3.0, 0))
    local height     = math.max(math.abs(footScreen.Y - topScreen.Y), 2)
    local width      = height * 0.55
    
    if STATE.ESPBoxPulse then
        local p = math.sin(tick() * 2.5) * 0.02
        height = height + (height * p)
        width = width + (width * p)
    end
    
    local vis = isVisible(hrp)
    local dynamicClr = vis and STATE.ESPVisibleColor or STATE.ESPColor

    local tracerClr  = STATE.ESPTracerColor
    local hp = (hum and hum.MaxHealth > 0) and (hum.Health / hum.MaxHealth) or 1

    local nameClr    = STATE.ESPNameColor
    local distClr    = STATE.ESPDistanceColor
    local headDotClr = STATE.ESPHeadDotColor
    local skelClr    = vis and STATE.ESPSkeletonVisibleColor or STATE.ESPSkeletonColor
    
    local hBarClr    = STATE.ESPHealthBarColor
    if STATE.ESPHealthBarStyle == "Gradient" then
        hBarClr = STATE.ESPHealthBarColorLow:Lerp(STATE.ESPHealthBarColorHigh, hp)
    end

    local cFillClr = vis and STATE.ESPChamsFillVisibleColor or STATE.ESPChamsFillColor
    local cOutlineClr = vis and STATE.ESPChamsOutlineVisibleColor or STATE.ESPChamsOutlineColor

    if STATE.ESPRainbow then
        local hue = tick() % 5 / 5
        local rainbowColor = Color3.fromHSV(hue, 1, 1)
        dynamicClr = rainbowColor
        tracerClr = rainbowColor
        nameClr = rainbowColor
        distClr = rainbowColor
        headDotClr = rainbowColor
        skelClr = rainbowColor
        hBarClr = rainbowColor
        cFillClr = rainbowColor
        cOutlineClr = rainbowColor
    end
    local centerX    = hrpPos.X
    local left       = centerX - width/2
    local right      = centerX + width/2
    local top        = topScreen.Y
    local bot        = footScreen.Y

    local style      = STATE.ESPBoxStyle
    local showFull   = (style == "Full Box") and STATE.ESPBox
      local showCorner = (style == "Corner Box") and STATE.ESPBox
      local espFont    = (Drawing and Drawing.Fonts) and Drawing.Fonts[STATE.ESPFont] or 0
      
      local espSize = STATE.ESPTextSize
      local textOffset = 0    -- Box gradient (rotates while Animated Box is on)
    local useGradient = STATE.ESPBoxGradient
    local gradC1 = STATE.ESPBoxColor
    local gradC2 = STATE.ESPBoxColor2
    if STATE.ESPRainbow then gradC1 = dynamicClr end
    local gPhase = STATE.ESPBoxPulse and (tick() * 1.5) or 0.785
    local gdx, gdy = math.cos(gPhase), math.sin(gPhase)
    local gcx, gcy = (left + right) / 2, (top + bot) / 2
    local maxProj = (width / 2) * math.abs(gdx) + (height / 2) * math.abs(gdy)
    if maxProj < 1 then maxProj = 1 end
    local function gradAt(px, py)
        local s = ((px - gcx) * gdx + (py - gcy) * gdy) / maxProj
        return gradC1:Lerp(gradC2, math.clamp((s + 1) / 2, 0, 1))
    end

    obj.Box.Visible = showFull and not useGradient
    obj.BoxOutline.Visible = showFull
    if showFull then
        if not useGradient then
            obj.Box.Size     = Vector2.new(width, height)
            obj.Box.Position = Vector2.new(left, top)
            obj.Box.Color    = dynamicClr
            obj.Box.Thickness = STATE.ESPBoxThickness
        end

        obj.BoxOutline.Size     = Vector2.new(width, height)
        obj.BoxOutline.Position = Vector2.new(left, top)
        obj.BoxOutline.Thickness = STATE.ESPBoxThickness + 2
    end

    -- Gradient box edges (Full Box only)
    do
        local showGrad = showFull and useGradient
        local gEdges = {
            { Vector2.new(left,  top), Vector2.new(right, top) },
            { Vector2.new(right, top), Vector2.new(right, bot) },
            { Vector2.new(right, bot), Vector2.new(left,  bot) },
            { Vector2.new(left,  bot), Vector2.new(left,  top) },
        }
        for i = 1, 4 do
            local ln = obj.GradLines[i]
            if showGrad then
                local a, b = gEdges[i][1], gEdges[i][2]
                ln.From = a; ln.To = b
                ln.Color = gradAt((a.X + b.X) / 2, (a.Y + b.Y) / 2)
                ln.Thickness = STATE.ESPBoxThickness
                ln.Visible = true
            else
                ln.Visible = false
            end
        end
    end

    obj.BoxFill.Visible = showFull and STATE.ESPBoxFill
    if obj.BoxFill.Visible then
        obj.BoxFill.Size     = Vector2.new(width, height)
        obj.BoxFill.Position = Vector2.new(left, top)
        obj.BoxFill.Color    = dynamicClr
        obj.BoxFill.Transparency = STATE.ESPFillTransparency
    end

    local cx, cy = width * 0.25, height * 0.25
    local corners = {
        { Vector2.new(left,  top), Vector2.new(left + cx, top),  Vector2.new(left,  top + cy)  },
        { Vector2.new(right, top), Vector2.new(right - cx, top), Vector2.new(right, top + cy)  },
        { Vector2.new(left,  bot), Vector2.new(left + cx, bot),  Vector2.new(left,  bot - cy)  },
        { Vector2.new(right, bot), Vector2.new(right - cx, bot), Vector2.new(right, bot - cy)  },
    }
    local li = 1
    for _, c in ipairs(corners) do
        local cornerClr = useGradient and gradAt(c[1].X, c[1].Y) or dynamicClr
        obj.CornerLines[li].From    = c[1]; obj.CornerLines[li].To    = c[2]
        obj.CornerLines[li].Color   = cornerClr; obj.CornerLines[li].Visible = showCorner; obj.CornerLines[li].Thickness = STATE.ESPBoxThickness
        obj.CornerLines[li+1].From  = c[1]; obj.CornerLines[li+1].To  = c[3]
        obj.CornerLines[li+1].Color = cornerClr; obj.CornerLines[li+1].Visible = showCorner; obj.CornerLines[li+1].Thickness = STATE.ESPBoxThickness
        li = li + 2
    end

    obj.Tracer.Visible = STATE.ESPTracer
    if STATE.ESPTracer then
        local camera = Workspace.CurrentCamera
        local originPos = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y) -- Bottom
        if STATE.ESPTracerOrigin == "Top" then
            originPos = Vector2.new(camera.ViewportSize.X/2, 0)
        elseif STATE.ESPTracerOrigin == "Center" then
            originPos = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
        elseif STATE.ESPTracerOrigin == "Mouse" then
            local userInput = game:GetService("UserInputService")
            local mouseLoc = userInput:GetMouseLocation()
            originPos = mouseLoc
        end

        obj.Tracer.From  = originPos
        obj.Tracer.To    = Vector2.new(centerX, bot)
        obj.Tracer.Color = tracerClr
    end

    obj.Name.Visible = STATE.ESPName
    if STATE.ESPName then
          local p = ESP_PLAYER_MAP[char] or Players:GetPlayerFromCharacter(char)
          local rawName = p and (p.DisplayName or p.Name) or char.Name
          if STATE.CensorText then
              rawName = STATE.CensorRenameText
          end
          
          obj.Name.Text = rawName
          obj.Name.Size     = espSize
          obj.Name.Font     = espFont
          obj.Name.Position = Vector2.new(centerX, top - (espSize + 2))
          obj.Name.Color    = nameClr
          obj.Name.Outline  = STATE.ESPTextOutline
    end

    obj.DistText.Visible = STATE.ESPDistance
    if STATE.ESPDistance then
        local rawDist = math.floor(dist) .. "m"
        obj.DistText.Text = rawDist
        
        obj.DistText.Size     = math.max(espSize - 2, 8)
        obj.DistText.Font     = espFont
        obj.DistText.Position = Vector2.new(centerX, bot + 3)
        obj.DistText.Color    = distClr
        obj.DistText.Outline  = STATE.ESPTextOutline
        textOffset = textOffset + espSize
    end

    local headPart = char:FindFirstChild("Head")
    obj.HeadDot.Visible = STATE.ESPHeadDot and headPart ~= nil
    if obj.HeadDot.Visible then
        local headScreen, headOnScreen = worldToScreen(headPart.Position)
        if headOnScreen then
            obj.HeadDot.Position = headScreen
            obj.HeadDot.Color = headDotClr
            obj.HeadDot.Radius = (3000 / depth) * 0.05
        else
            obj.HeadDot.Visible = false
        end
    end    if STATE.ESPLevel then
        local p = ESP_PLAYER_MAP[char] or Players:GetPlayerFromCharacter(char)
        local lvl = (p and p:FindFirstChild("leaderstats") and p.leaderstats:FindFirstChild("Level")) and p.leaderstats.Level.Value or "?"
        
    end

    if STATE.ESPHealthBar then
        local curHealth = hum and hum.Health or 100
        local maxHealth = hum and hum.MaxHealth or 100
        pcall(function()
            local States = require(ReplicatedStorage.Modules.States)
            if States then
                local realHealth = States:GetStateValue(char, "Health")
               
                if realHealth then
                    curHealth = realHealth
                    maxHealth = 150
                end
            end
        end)
        
        local cachedHealth = PREVIOUS_ENEMY_HEALTH[char]
        if cachedHealth then
            if curHealth < cachedHealth and curHealth > 0 then
                local lastShot = getgenv()._sa_lastLocalShot or 0
                if tick() - lastShot < 0.5 then
                    playHitSound()
                end
            end
        end
        PREVIOUS_ENEMY_HEALTH[char] = curHealth

        if maxHealth <= 0 then maxHealth = 100 end
        local ratio   = math.clamp(curHealth / maxHealth, 0, 1)
        local barX    = left - 6
        local segH    = height / 20
        local filledY = bot - height * ratio
        obj.HealthBG.From    = Vector2.new(barX, top)
        obj.HealthBG.To      = Vector2.new(barX, bot)
        obj.HealthBG.Visible = true
        for i, seg in ipairs(obj.HealthSegs) do
            local segTop = top + (i - 1) * segH
            local segBot = segTop + segH
            if segBot >= filledY then
                seg.From    = Vector2.new(barX, math.max(segTop, filledY))
                seg.To      = Vector2.new(barX, segBot)
                seg.Visible = true
                if STATE.ESPHealthBarStyle == "Solid" then
                    seg.Color = hBarClr
                else
                    if STATE.ESPRainbow then
                        seg.Color = hBarClr
                    else
                        local t = (i - 1) / 19
                        seg.Color = STATE.ESPHealthBarColorHigh:Lerp(STATE.ESPHealthBarColorLow, t)
                    end
                end
            else
                seg.Visible = false
            end
        end
    else
        obj.HealthBG.Visible = false
        for _, seg in ipairs(obj.HealthSegs) do seg.Visible = false end
    end

    if STATE.ESPSkeleton then
        for i, conn in ipairs(SKELETON_CONNECTIONS) do
            local p1 = char:FindFirstChild(conn[1])
            local p2 = char:FindFirstChild(conn[2])
            local ln = obj.Skeleton[i]
            if p1 and p2 then
                local s1, on1 = worldToScreen(p1.Position)
                local s2, on2 = worldToScreen(p2.Position)
                ln.Visible = on1 or on2
                if ln.Visible then ln.From = s1; ln.To = s2; ln.Color = skelClr end
            else
                ln.Visible = false
            end
        end
    else
        for _, ln in ipairs(obj.Skeleton) do ln.Visible = false end
    end

    if STATE.ESPChams then
        obj.Highlight.Enabled = true
        obj.Highlight.FillColor = cFillClr
        obj.Highlight.OutlineColor = cOutlineClr
        obj.Highlight.FillTransparency = STATE.ESPChamsFillTransparency
        obj.Highlight.OutlineTransparency = STATE.ESPChamsOutlineTransparency
        obj.Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    else
        obj.Highlight.Enabled = false
    end
end


-- ===== SILENT AIM / AUTO SHOOT / CURVE BULLETS / EYE-ORIGIN VISUALIZER =====
-- Chickynoid networking hooks. Every feature below is INDEPENDENT -- none of them borrow
-- behaviour from another:
--   * SilentAim  -> spoofs the outgoing command's view angles toward the FOV target, then
--                   restores them in ClientChickynoid.Heartbeat AFTER the command is sent,
--                   so shots register server-side while the camera never visibly moves.
--   * AutoShoot  -> ONLY sets the fire button on the command (auto-fires the weapon). It
--                   never rotates the view and never touches the eye-origin visual.
--   * CurveBullets -> redirects the client "Shot" effect toward the target (Effects.Identify).
local eyeOrigin
pcall(function() eyeOrigin = require(ReplicatedStorage.Modules.Shared.EyeOrigin) end)

local savedRotation

-- Cached module references. Also consumed by cleanup_script() to unhook cleanly on unload.
local sa_ClientModule, sa_ClientChickynoid, sa_effects, sa_cameraHandler

local function getSACameraHandler()
    if not sa_cameraHandler then
        pcall(function() sa_cameraHandler = require(ReplicatedStorage.Modules.Handlers.CameraHandler) end)
    end
    return sa_cameraHandler
end

-- Vector3 view-angle that points from the authoritative eye origin to the target part.
local function computeAimRotation(self, part)
    local ch = getSACameraHandler()
    if not ch or not part then return nil, ch end
    local sim = self and self.localChickynoid and self.localChickynoid.simulation
    local simState = sim and sim.state
    local origin = (simState and eyeOrigin and eyeOrigin.getAuthoritative(simState)) or Workspace.CurrentCamera.CFrame.Position
    local direction = (part.Position - origin).Unit
    local baseZ = (typeof(ch.currentRotation) == "Vector3" and ch.currentRotation.Z) or 0
    return Vector3.new(math.asin(math.clamp(direction.Y, -1, 1)), math.atan2(-direction.X, -direction.Z), baseZ), ch
end

pcall(function()
    sa_ClientModule = require(ReplicatedFirst.Packages.Chickynoid.Client.ClientModule)
    if sa_ClientModule then
        getgenv().sa_generate = getgenv().sa_generate or sa_ClientModule.GenerateCommandBase
        local originalGenerate = getgenv().sa_generate
        sa_ClientModule.GenerateCommandBase = function(self, ...)
            if STATE.IsUnloaded then return originalGenerate(self, ...) end
            local part = STATE.CurrentAimTarget
            pcall(function()
                -- Silent Aim ONLY: spoof the view angles toward the target for this command.
                if STATE.SilentAim and part and savedRotation == nil then
                    if math.random(1, 100) > (STATE.SilentAimHitChance or 100) then return end
                    local rot, ch = computeAimRotation(self, part)
                    if rot and ch then
                        savedRotation = ch.currentRotation
                        ch.currentRotation = rot
                    end
                end
            end)
            local command = originalGenerate(self, ...)
            pcall(function()
                -- Auto Shoot & Triggerbot: set the internal fire command flag and hold the trigger.
                local shouldFire = false
                if STATE.AutoShoot and part then
                    shouldFire = true
                end
                if STATE.Triggerbot and STATE.TriggerBotFiring then
                    shouldFire = true
                end

                if command and shouldFire then
                    command.buttons = bit32.bor(command.buttons or 0, 1)
                    command.fire = 1
                end
            end)
            return command
        end
    end
end)

pcall(function()
    sa_ClientChickynoid = require(ReplicatedFirst.Packages.Chickynoid.Client.ClientChickynoid)
    if sa_ClientChickynoid then
        getgenv().sa_heartbeat = getgenv().sa_heartbeat or sa_ClientChickynoid.Heartbeat
        local originalHeartbeat = getgenv().sa_heartbeat
        sa_ClientChickynoid.Heartbeat = function(self, ...)
            local result = originalHeartbeat(self, ...)
            -- Restore the spoofed rotation AFTER the command has been processed.
            pcall(function()
                if savedRotation ~= nil then
                    local ch = getSACameraHandler()
                    if ch then ch.currentRotation = savedRotation end
                    savedRotation = nil
                end
            end)
            return result
        end
    end
end)

pcall(function()
    sa_effects = require(ReplicatedStorage.Modules.Handlers.Effects)
    if sa_effects and sa_effects.Identify then
        getgenv().sa_identify = getgenv().sa_identify or sa_effects.Identify
        local originalIdentify = getgenv().sa_identify
        sa_effects.Identify = function(self, id, ...)
            local args = { ... }
            if not STATE.IsUnloaded then
                pcall(function()
                    local target = STATE.CurrentAimTarget
                    if id == "Shot" and args[4] and type(args[4]) == "table" and args[4].fromServer ~= true then
                        getgenv()._sa_lastLocalShot = tick()
                    end
                    if id == "Shot" and STATE.CurveBullets and target and target.Parent then
                        local shot = args[4]
                        if type(shot) == "table" and shot.fromServer ~= true then
                            local headPosition = target.Position
                            local origin = shot.origin or Workspace.CurrentCamera.CFrame.Position
                            shot.hitPos = headPosition
                            shot.direction = (headPosition - origin).Unit
                            shot.hitObject = target
                            shot.limbHit = "head"
                        end
                    end

                    -- Bullet Tracers: draw a fading neon beam from the shot origin to
                    -- its impact point. Runs after CurveBullets so it follows the final path.
                    if id == "Shot" and STATE.BulletTracers and type(args[4]) == "table" then
                        local shot = args[4]
                        local origin = shot.origin
                        local endPos = shot.hitPos
                        if (not endPos) and origin and shot.direction then
                            endPos = origin + shot.direction * 500
                        end
                        if origin and endPos then
                            local cam = Workspace.CurrentCamera
                            local startPos = origin
                            -- If the shot originates at the camera (our own shot), start it
                            -- from a gun-like offset so the tracer doesn't clip the screen.
                            if cam and (origin - cam.CFrame.Position).Magnitude < 4 then
                                startPos = (cam.CFrame * CFrame.new(0.8, -0.8, -1.2)).Position
                            end
                            local dist = (endPos - startPos).Magnitude
                            if dist > 0.5 then
                                local tracerColor = STATE.BulletTracersColor or Color3.fromRGB(240, 240, 240)
                                local baseTransparency = STATE.BulletTracerTransparency or 0
                                local decay = math.max(0.05, STATE.BulletTracerDecay or 0.4)
                                task.spawn(function()
                                    local beam = Instance.new("Part")
                                    beam.Anchored = true
                                    beam.CanCollide = false
                                    beam.CanQuery = false
                                    beam.CanTouch = false
                                    beam.CastShadow = false
                                    beam.Material = Enum.Material.Neon
                                    beam.Color = tracerColor
                                    beam.Size = Vector3.new(0.12, 0.12, dist)
                                    beam.CFrame = CFrame.lookAt(startPos, endPos) * CFrame.new(0, 0, -dist / 2)
                                    beam.Transparency = baseTransparency
                                    beam.Parent = Workspace
                                    local elapsed = 0
                                    while elapsed < decay do
                                        if not beam.Parent then break end
                                        local alpha = elapsed / decay
                                        beam.Transparency = baseTransparency + (1 - baseTransparency) * alpha
                                        elapsed = elapsed + task.wait()
                                    end
                                    beam:Destroy()
                                end)
                            end
                        end
                    end
                end)
            end
            return originalIdentify(self, id, ...)
        end
    end
end)

