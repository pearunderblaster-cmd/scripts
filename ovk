        local result = Workspace:Raycast(camera.CFrame.Position, camera.CFrame.LookVector * STATE.TriggerbotRange, params)
        local isEnemyPart = false
        if result and result.Instance then
            local hitPart = result.Instance



            for char, _ in pairs(currentCharacters) do
                if hitPart:IsDescendantOf(char) then
                    isEnemyPart = true
                    break
                end
            end
        end
        
        if isEnemyPart then
            if not STATE.TriggerBotStartedTimer then
                STATE.TriggerBotStartedTimer = tick()
           
            end
            if not STATE.TriggerBotFiring and (tick() - STATE.TriggerBotStartedTimer) >= (STATE.TriggerbotDelay / 1000) then
                STATE.TriggerBotFiring = true
            end
        else
            STATE.TriggerBotStartedTimer = nil
            if STATE.TriggerBotFiring then
                STATE.TriggerBotFiring = false
            end
        end
    elseif STATE.TriggerBotFiring then
        STATE.TriggerBotStartedTimer = nil
        STATE.TriggerBotFiring = false
    end
end)

-- Camera-lock aimbot. Bound at the Last render priority so our camera write happens AFTER
-- the game's own camera update each frame (otherwise it gets overwritten - the old bug).
RunService:BindToRenderStep("RB_AimLock", Enum.RenderPriority.Last.Value, function(dt)
    if STATE.IsUnloaded or not STATE.MasterSwitch then return end
    
    if STATE.Aimbot and IsAiming then
        aimAt(STATE.CurrentAimTarget, dt)
    end

    -- ViewModel Offsets: the viewmodel is rebuilt inside workspace.World.FX every
    -- frame at Camera priority; this loop runs at Last priority so we nudge it after.
    -- We build a camera-relative delta so X/Y/Z and Pitch/Yaw/Roll act in view space.
    if STATE.CustomViewModelToggle then
        local cam = Workspace.CurrentCamera
        local fx = Workspace:FindFirstChild("World") and Workspace.World:FindFirstChild("FX")
        if cam and fx then
            local camCF = cam.CFrame
            local offCF = CFrame.new(STATE.VMOffsetX, STATE.VMOffsetY, STATE.VMOffsetZ)
                * CFrame.Angles(math.rad(STATE.VMPitch), math.rad(STATE.VMYaw), math.rad(STATE.VMRoll))
            local delta = camCF * offCF * camCF:Inverse()
            local camPos = camCF.Position
            for _, m in ipairs(fx:GetChildren()) do
                if m:IsA("Model") then
                    local ok, pivot = pcall(function() return m:GetPivot() end)
                    if ok and pivot and (pivot.Position - camPos).Magnitude <= 14 then
                        pcall(function() m:PivotTo(delta * pivot) end)
                    end
                elseif m:IsA("BasePart") then
                    if (m.Position - camPos).Magnitude <= 14 then
                        pcall(function() m.CFrame = delta * m.CFrame end)
                    end
                end
            end
        end
    end


    


    local myChar = getLocalCharacter()
    if STATE.ThirdPerson then
        if STATE.ThirdPersonMode == "Classic" then
            -- Force character visible
            if myChar then
                for _, v in ipairs(myChar:GetDescendants()) do
                    if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                        v.LocalTransparencyModifier = 0
                        if v.Transparency >= 1 then
                            v.Transparency = 0
                        end
                        -- Also catch decals (like faces) if they were hidden
                    elseif v:IsA("Decal") and v.Name == "face" then
                        v.LocalTransparencyModifier = 0
                        v.Transparency = 0
                    end
                end
            end
            
            -- Hide the weapon viewmodel every frame for Classic
            pcall(function()
                local vm = require(game:GetService("ReplicatedStorage").Modules.WeaponECS.Render.ViewModel)
                if vm and vm.getControllers and myChar then
                    local controllers = vm.getControllers(myChar)
                    if controllers then
                        for _, ctrl in pairs(controllers) do
                            if ctrl.setTransparency then ctrl:setTransparency(1) end
                        end
                    end
                end
                local render = require(game:GetService("ReplicatedStorage").Modules.WeaponECS.Render)
                if render and render.viewModelController and render.viewModelController.setTransparency then
                    render.viewModelController:setTransparency(1)
                end
            end)
        else
            -- Viewmodel mode: show viewmodel, offset camera manually
            if myChar then
                for _, v in ipairs(myChar:GetDescendants()) do
                    if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                        v.LocalTransparencyModifier = 1
                        if v.Transparency < 1 and v.Name ~= "Head" then
                            v.Transparency = 1
                        end
                    elseif v:IsA("Decal") and v.Name == "face" then
                        v.LocalTransparencyModifier = 1
                        v.Transparency = 1
                    end
                end
            end

            -- Ensure viewmodel is fully visible
            pcall(function()
                local vm = require(game:GetService("ReplicatedStorage").Modules.WeaponECS.Render.ViewModel)
                if vm and vm.getControllers and myChar then
                    local controllers = vm.getControllers(myChar)
                    if controllers then
                        for _, ctrl in pairs(controllers) do
                            if ctrl.setTransparency then ctrl:setTransparency(0) end
                        end
                    end
                end
                local render = require(game:GetService("ReplicatedStorage").Modules.WeaponECS.Render)
                if render and render.viewModelController and render.viewModelController.setTransparency then
                    render.viewModelController:setTransparency(0)
                end
            end)
        end

        local camera = Workspace.CurrentCamera
        if camera then
            local offsetDist = STATE.ThirdPersonZoom or 10
            local rightOffset = 2
            local upOffset = 1.5
            local offsetDir = (camera.CFrame.RightVector * rightOffset) + (camera.CFrame.UpVector * upOffset) - (camera.CFrame.LookVector * offsetDist)
            local params = RaycastParams.new()
            local ignoreList = {camera}
            if myChar then table.insert(ignoreList, myChar) end
            if DomeFolder then table.insert(ignoreList, DomeFolder) end
            params.FilterDescendantsInstances = ignoreList
            params.FilterType = Enum.RaycastFilterType.Exclude
            local res = Workspace:Raycast(camera.CFrame.Position, offsetDir, params)
            local targetPos = res and (res.Position + res.Normal * 0.5) or (camera.CFrame.Position + offsetDir)
            camera.CFrame = CFrame.new(targetPos, targetPos + camera.CFrame.LookVector)
        end
    else
        -- Restore LocalTransparencyModifier so the engine hides character in first person as normal.
        if myChar then
            for _, v in ipairs(myChar:GetDescendants()) do
                if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                    v.LocalTransparencyModifier = 1
                end
            end
        end
    end

    -- Stretch Resolution: scale the view axes to stretch the rendered image.
    -- Vertical amount stretches things taller, horizontal amount stretches wider.
    if STATE.StretchRes and ((STATE.StretchResAmount or 0) > 0 or (STATE.StretchResHorizontal or 0) > 0) then
        local cam = Workspace.CurrentCamera
        if cam then
            local vAmt = STATE.StretchResAmount or 0
            local hAmt = STATE.StretchResHorizontal or 0
            local yScale = math.max(0.05, 1 / (1 + vAmt / 30))
            local xScale = math.max(0.05, 1 / (1 + hAmt / 30))
            cam.CFrame = cam.CFrame * CFrame.new(0,0,0, xScale,0,0, 0,yScale,0, 0,0,1)
        end
    end

    for char in pairs(ESP_OBJECTS) do
        updateESP(char)
    end
end)

