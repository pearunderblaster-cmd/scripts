local function startWeaponEnforcer()
    if weaponEnforcerConn then return end

    -- Tables do not emit GetPropertyChangedSignal, therefore we loop to persistently check and correct mismatched values
    weaponEnforcerConn = RunService.Heartbeat:Connect(function()
        local modules = getWeaponModules()
        for _, data in ipairs(modules) do
            local item = data.instance
            local mod = data.mod
            
            if not weaponModsCache[item] then
                local function dc(t) 
                    local res = {} 
                    for k,v in pairs(t) do res[k] = type(v)=="table" and dc(v) or v end 
                    return res 
                end
                weaponModsCache[item] = {
                    stats = dc(mod.stats),
                    sounds = mod.sounds and dc(mod.sounds) or {}
                }
            end
            
            local orig = weaponModsCache[item].stats
            local origSounds = weaponModsCache[item].sounds
            
            if mod.stats.handling then
                local targSpeed = STATE.WeaponModsSpeedEnabled and STATE.WeaponModsSpeed or orig.handling.speedMultiplier
                if mod.stats.handling.speedMultiplier ~= targSpeed then mod.stats.handling.speedMultiplier = targSpeed end
            end
            
            if mod.stats.firing then
                local targRate = STATE.WeaponModsFireRateEnabled and STATE.WeaponModsFireRate or orig.firing.rate
                if mod.stats.firing.rate ~= targRate then mod.stats.firing.rate = targRate end

                local targDist = STATE.WeaponModsInfRange and math.huge or orig.firing.maxDistance
                if mod.stats.firing.maxDistance ~= targDist then mod.stats.firing.maxDistance = targDist end
            end
            if mod.sounds then
                for soundName, soundData in pairs(mod.sounds) do
                    local lowerName = string.lower(soundName)
                    local isFire = lowerName:match("fire") or lowerName:match("shoot")
                    local isReload = lowerName:match("reload")
                    
                    if isFire and origSounds[soundName] then
                        local targFireSound = STATE.WeaponModsFireSoundEnabled and shootSoundIds[STATE.WeaponModsFireSound] or origSounds[soundName].SoundId
                        if soundData.SoundId ~= targFireSound then
                            soundData.SoundId = targFireSound
                        end
                    elseif isReload and origSounds[soundName] then
                        local targReloadSound = STATE.WeaponModsReloadSoundEnabled and reloadSoundIds[STATE.WeaponModsReloadSound] or origSounds[soundName].SoundId
                        if soundData.SoundId ~= targReloadSound then
                            soundData.SoundId = targReloadSound
                        end
                    end
                end
            end
        end
        
        -- Populate known sound IDs for instant playback interception
        pcall(function()
            local knownFire = {}
            local knownReload = {}
            for _, id in pairs(shootSoundIds) do knownFire[tostring(id)] = true; knownFire["rbxassetid://" .. id] = true end
            for _, id in pairs(reloadSoundIds) do knownReload[tostring(id)] = true; knownReload["rbxassetid://" .. id] = true end

            for item, cachedData in pairs(weaponModsCache) do
                if cachedData.sounds then
                    for soundName, soundData in pairs(cachedData.sounds) do
                        local lowerName = string.lower(soundName)
                        if lowerName:match("fire") or lowerName:match("shoot") then
                            if soundData.SoundId then
                                knownFire[tostring(soundData.SoundId)] = true
                                knownFire["rbxassetid://" .. soundData.SoundId] = true
                                knownFire[soundData.SoundId] = true
                            end
                        elseif lowerName:match("reload") then
                            if soundData.SoundId then
                                knownReload[tostring(soundData.SoundId)] = true
                                knownReload["rbxassetid://" .. soundData.SoundId] = true
                                knownReload[soundData.SoundId] = true
                            end
                        end
                    end
                end
            end
            STATE.KnownFireSounds = knownFire
            STATE.KnownReloadSounds = knownReload
        end)
    end)
end
