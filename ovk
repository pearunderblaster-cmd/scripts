    for i = 1, 6 do
        local p = Instance.new("Part")
        p.Anchored = true
        p.CanCollide = false
        p.CastShadow = false
        p.Parent = DomeFolder
        p.Transparency = 1
        table.insert(domeParts, p)
    end
end

local function updateDome()
    if not DomeFolder or DomeFolder.Parent ~= Workspace then
        initDome()
    end

    if not STATE.MapDome or not STATE.MasterSwitch then
        for _, p in ipairs(domeParts) do p.Transparency = 1 end
        return
    end

    local mapsHolder = Workspace:FindFirstChild("World") and Workspace.World:FindFirstChild("Map")
    if not mapsHolder then 
        for _, p in ipairs(domeParts) do p.Transparency = 1 end
        return 
    end

    -- Fast bounding box calculation
    local minObj = Vector3.new(math.huge, math.huge, math.huge)
    local maxObj = Vector3.new(-math.huge, -math.huge, -math.huge)
    local hasParts = false
    for _, v in ipairs(mapsHolder:GetDescendants()) do
        if v:IsA("BasePart") then
            hasParts = true
            local p = v.Position
            local s = v.Size / 2
            local m1, m2 = p - s, p + s
            minObj = Vector3.new(math.min(minObj.X, m1.X), math.min(minObj.Y, m1.Y), math.min(minObj.Z, m1.Z))
            maxObj = Vector3.new(math.max(maxObj.X, m2.X), math.max(maxObj.Y, m2.Y), math.max(maxObj.Z, m2.Z))
        end
    end

    if not hasParts then
        for _, p in ipairs(domeParts) do p.Transparency = 1 end
        return
    end
    
    local center = (minObj + maxObj) / 2
    local size = (maxObj - minObj) + Vector3.new(50, 50, 50) -- Padding around the map
    
    -- Roblox max part size clamping
    size = Vector3.new(math.clamp(size.X, 0, 2048), math.clamp(size.Y, 0, 2048), math.clamp(size.Z, 0, 2048))

    local c = STATE.MapDomeColor
    local mStr = STATE.MapDomeMaterial
    local m = Enum.Material.ForceField
    pcall(function() m = Enum.Material[mStr] end)
    local t = STATE.MapDomeTransparency
    
    -- Thickness
    local th = 5

    -- Top
    domeParts[1].Size = Vector3.new(size.X, th, size.Z)
    domeParts[1].CFrame = CFrame.new(center + Vector3.new(0, size.Y/2, 0))
    -- Bottom
    domeParts[2].Size = Vector3.new(size.X, th, size.Z)
    domeParts[2].CFrame = CFrame.new(center + Vector3.new(0, -size.Y/2, 0))
    -- Left
    domeParts[3].Size = Vector3.new(th, size.Y, size.Z)
    domeParts[3].CFrame = CFrame.new(center + Vector3.new(-size.X/2, 0, 0))
    -- Right
    domeParts[4].Size = Vector3.new(th, size.Y, size.Z)
    domeParts[4].CFrame = CFrame.new(center + Vector3.new(size.X/2, 0, 0))
    -- Front
    domeParts[5].Size = Vector3.new(size.X, size.Y, th)
    domeParts[5].CFrame = CFrame.new(center + Vector3.new(0, 0, -size.Z/2))
    -- Back
    domeParts[6].Size = Vector3.new(size.X, size.Y, th)
    domeParts[6].CFrame = CFrame.new(center + Vector3.new(0, 0, size.Z/2))

    for _, p in ipairs(domeParts) do
        p.Color = c
        p.Material = m
        p.Transparency = t
    end
end
