local function isVisible(part)
    local origin = Workspace.CurrentCamera.CFrame.Position
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.IgnoreWater = true
    
    local filter = {Workspace.CurrentCamera}
    local localChar = getLocalCharacter()
    if localChar then table.insert(filter, localChar) end
    
    params.FilterDescendantsInstances = filter
    
    for _, possibleHit in ipairs(Workspace:GetPartBoundsInRadius(origin, 0.1)) do
        table.insert(filter, possibleHit)
    end
    params.FilterDescendantsInstances = filter
    
    local cf = part.CFrame
    local size = part.Size
    local offsets = {
        Vector3.new(0, 0, 0),
        Vector3.new(size.X/2.2, size.Y/2.2, 0),
        Vector3.new(-size.X/2.2, size.Y/2.2, 0),
        Vector3.new(size.X/2.2, -size.Y/2.2, 0),
        Vector3.new(-size.X/2.2, -size.Y/2.2, 0),
    }
    
    local visibleHits = 0
    for _, offset in ipairs(offsets) do
        local targetPos = cf * offset
        local dir = targetPos - origin
        local result = Workspace:Raycast(origin, dir + dir.Unit, params)
        
        if result then
            if result.Instance:IsDescendantOf(part.Parent) then
                visibleHits = visibleHits + 1
            end
        else
            visibleHits = visibleHits + 1
        end
    end
    
    return visibleHits >= 3
end

local DomeFolder = nil
