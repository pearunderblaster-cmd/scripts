local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    if STATE.IsUnloaded then return oldNamecall(self, ...) end
    local method = getnamecallmethod()

    if not checkcaller() and method == "Play" and typeof(self) == "Instance" and self.ClassName == "Sound" then
        if STATE.KnownFireSounds and STATE.WeaponModsFireSoundEnabled then
            if STATE.KnownFireSounds[self.SoundId] then
                self.SoundId = "rbxassetid://" .. shootSoundIds[STATE.WeaponModsFireSound]
            end
        end
        if STATE.KnownReloadSounds and STATE.WeaponModsReloadSoundEnabled then
            -- Only replace reload sounds if they aren't also matching something that is considered a Fire sound
            if STATE.KnownReloadSounds[self.SoundId] and not STATE.KnownFireSounds[self.SoundId] then
                self.SoundId = "rbxassetid://" .. reloadSoundIds[STATE.WeaponModsReloadSound]
            end
        end
    end
    
    if not checkcaller() and method == "CreateSound" then
        if STATE.KnownFireSounds and STATE.WeaponModsFireSoundEnabled then
            local args = {...}
            if type(args[1]) == "string" and STATE.KnownFireSounds[args[1]] then
                args[1] = "rbxassetid://" .. shootSoundIds[STATE.WeaponModsFireSound]
                return oldNamecall(self, unpack(args))
            end
        end
        if STATE.KnownReloadSounds and STATE.WeaponModsReloadSoundEnabled then
            local args = {...}
            -- Make sure the sound is not also a known fire sound before processing as reload
            if type(args[1]) == "string" and STATE.KnownReloadSounds[args[1]] and not STATE.KnownFireSounds[args[1]] then
                args[1] = "rbxassetid://" .. reloadSoundIds[STATE.WeaponModsReloadSound]
                return oldNamecall(self, unpack(args))
            end
        end
    end

    return oldNamecall(self, ...)
end)

