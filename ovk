local function getClosestInFOV()
    local camera = Workspace.CurrentCamera
    local center = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    local closest = nil
    
    local isFovSelection = STATE.AimTargetSelection == "FOV"
    local bestScore = isFovSelection and STATE.AimFOV or math.huge

    local targets = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not isEnemy(player) then continue end

        local char = player.Character
        if not char or not isAlive(char) then
            local n = loadNeuron()
            if n then
                pcall(function()
                    local result = n:get_character(player)
                    if result and isAlive(result) then char = result end
                end)
            end
        end

        if char and isAlive(char) then
            table.insert(targets, char)
        end
    end

    if STATE.TargetNPCs then
        for _, char in ipairs(cachedNPCs) do
            if isAlive(char) then
                table.insert(targets, char)
            end
        end
    end

    for _, char in ipairs(targets) do
        local part = nil
        
        if STATE.HumanizeAim then
            local closestPartDist = math.huge
            local possibleParts = {"Head", "HumanoidRootPart", "Torso", "UpperTorso", "LowerTorso", "RightUpperArm", "LeftUpperArm", "RightLowerArm", "LeftLowerArm", "RightUpperLeg", "LeftUpperLeg", "RightLowerLeg", "LeftLowerLeg"}
            for _, pName in ipairs(possibleParts) do
                local testPart = char:FindFirstChild(pName)
                if testPart then
                    local screenPos, onScreen = camera:WorldToViewportPoint(testPart.Position)
                    if onScreen then
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                        if dist < closestPartDist then
                            closestPartDist = dist
                            part = testPart
                        end
                    end
                end
            end
            if not part then
                part = char.PrimaryPart or char:FindFirstChild("HumanoidRootPart")
            end
        else
            local hitPartName = STATE.AimPart
            if hitPartName == "Random" then
                local parts = {"Head", "HumanoidRootPart", "Torso", "UpperTorso", "LowerTorso", "RightUpperArm", "LeftUpperArm", "RightLowerArm", "LeftLowerArm", "RightUpperLeg", "LeftUpperLeg", "RightLowerLeg", "LeftLowerLeg"}
                hitPartName = parts[math.random(1, #parts)]
            end
            part = char:FindFirstChild(hitPartName) or char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
        end

        if not part then continue end

        local physicalDist = (part.Position - camera.CFrame.Position).Magnitude
        if physicalDist > STATE.AimMaxDistance then continue end

        local checkPos = part.Position
        if STATE.AimPrediction then
            checkPos = checkPos + (part.AssemblyLinearVelocity * STATE.AimPredictionAmount)
        end

        if STATE.AimVisibleOnly and not isVisible(part) then continue end

        local screenPos, onScreen = camera:WorldToViewportPoint(checkPos)
        if not onScreen then continue end

        local fovDist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if fovDist > STATE.AimFOV then continue end

        local score = isFovSelection and fovDist or physicalDist
        if score < bestScore then
            closest = part
            bestScore = score
        end
    end
    return closest
end

local cachedCameraHandler = nil
local humanizePhase = "Delay"
local phaseEndTime = 0
local microWindowStart = 0
local microWindowEnd = 0
local currentSway = Vector3.zero
local currentAlphaMult = 1

local nextMiniSwayTime = 0
local miniSwayEndTime = 0
local activeMiniSway = Vector3.zero
local currentMiniSway = Vector3.zero

local function aimAt(targetPart, dt)
    if not targetPart or not targetPart.Parent then 
        humanizePhase = "Tracking"
        phaseEndTime = 0
        currentAlphaMult = 1
        return 
    end

    local camera = Workspace.CurrentCamera
    if not camera then return end

    local pos = camera.CFrame.Position
    local targetPos = targetPart.Position

    if STATE.HumanizeAim then
       
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        local ignoreList = {camera}
        if LocalPlayer.Character then table.insert(ignoreList, LocalPlayer.Character) end
        rayParams.FilterDescendantsInstances = ignoreList

        local rayResult = Workspace:Raycast(pos, camera.CFrame.LookVector * STATE.AimMaxDistance, rayParams)
        
        local isHittingTarget = false
        if rayResult and rayResult.Instance and rayResult.Instance:IsDescendantOf(targetPart.Parent) then
            isHittingTarget = true
        end

        local targetAlphaMult = 1
        local targetSway = Vector3.zero
        local now = tick()
        local factor = STATE.HumanizeFactor or 5

        if isHittingTarget then
            humanizePhase = "Tracking"
            phaseEndTime = 0 -- force reroll to delay phase when we fall off target
            targetAlphaMult = 0 -- smooth stop
        else
            if now >= phaseEndTime then
                -- Switch phases cyclically to avoid robotic predictability
                if humanizePhase == "Delay" then
                    humanizePhase = "Tracking"
                    -- Track for a variable time
                    local trackDuration = (math.random(50, 150) / 100) * (1 + (factor * 0.2))
                    phaseEndTime = now + trackDuration
                else
                    humanizePhase = "Delay"
                    -- Scale delay window drastically based on factor. Made much sharper/shorter.
                    local delayDuration = (math.random(2, 15) / 100) * (factor * 0.15 + 0.05)
                    phaseEndTime = now + delayDuration
                    
                    -- Randomize the internal micro-window for subtle deviations during the delay
                    local microDuration = (math.random() * 0.4 + 0.1) * delayDuration
                    local microOffset = math.random() * (delayDuration - microDuration)
                    microWindowStart = now + microOffset
                    microWindowEnd = microWindowStart + microDuration
                end
            end

            if humanizePhase == "Delay" then
                if now >= microWindowStart and now <= microWindowEnd then
                    -- Inside mini randomize window: subtly wander instead of freezing entirely
                    targetAlphaMult = math.clamp(1 - (factor * 0.15), 0, 1)
                    local swaySpeed = 1.0 / (1 + (factor * 0.1))
                    local swayMagnitude = (STATE.AimSmoothness > 0 and math.clamp(STATE.AimSmoothness * 0.15, 0.05, 1) or 0.2) * (factor * 0.15 + 0.05)
                    
                    targetSway = Vector3.new(
                        math.noise(now * swaySpeed, 10, 10),
                        math.noise(10, now * swaySpeed, 10),
                        math.noise(10, 10, now * swaySpeed)
                    ) * swayMagnitude
                else
                    targetAlphaMult = math.clamp(0.8 - (factor * 0.15), 0, 1)
                end
            elseif humanizePhase == "Tracking" then
                targetAlphaMult = 1
                local swaySpeed = 0.5 / (1 + ( factor * 0.2)) 
                local swayMagnitude = (STATE.AimSmoothness > 0 and math.clamp(STATE.AimSmoothness * 0.2, 0.1, 1.5) or 0.3) * (factor * 0.15 + 0.05)
                
                targetSway = Vector3.new(
                        math.noise(now * swaySpeed, 0, 0),
                        math.noise(0, now * swaySpeed, 0),
                        math.noise(0, 0, now * swaySpeed)
                ) * swayMagnitude
            end

            -- Short, independent mini sways triggered randomly
              if now > nextMiniSwayTime then
                  nextMiniSwayTime = now + math.random(20, 80) / 100
                  miniSwayEndTime = now + math.random(5, 15) / 100
                  
                  local miniMag = (STATE.AimSmoothness > 0 and math.clamp(STATE.AimSmoothness * 0.1, 0.05, 0.4) or 0.1) * (factor / 5 + 0.1)
                  activeMiniSway = Vector3.new(math.random() - 0.5, math.random() - 0.5, math.random() - 0.5).Unit * miniMag
              end

              if now >= miniSwayEndTime then
                  activeMiniSway = Vector3.zero
              end
          end
          
          -- Smooth out all deviations organically
          currentMiniSway = currentMiniSway:Lerp(activeMiniSway, math.clamp(dt * 15, 0, 1))
          currentSway = currentSway:Lerp(targetSway + currentMiniSway, math.clamp(dt * 2, 0, 1))
          currentAlphaMult = currentAlphaMult + (targetAlphaMult - currentAlphaMult) * math.clamp(dt * 8, 0, 1)

          targetPos = targetPos + currentSway
      else
          humanizePhase = "Tracking"
          phaseEndTime = 0
          currentAlphaMult = 1
      end

      if STATE.AimPrediction then
        targetPos = targetPos + (targetPart.AssemblyLinearVelocity * STATE.AimPredictionAmount)
      end

      local alpha = 1
      if STATE.AimSmoothness > 0 then
          local smoothVariability = 1
          if STATE.HumanizeAim then
              local factor = STATE.HumanizeFactor or 5
              smoothVariability = 1 + (math.noise(tick() * 1.5, tick() * 1.5, 0) * (0.1 * factor))
          end
          alpha = math.clamp((1 / (STATE.AimSmoothness * smoothVariability)) * ((dt or 1/60) * 60), 0, 1)
      end
      
      if STATE.HumanizeAim then
          alpha = alpha * currentAlphaMult
      end

      local goal = CFrame.lookAt(pos, targetPos)

      if not cachedCameraHandler then
          pcall(function()
              cachedCameraHandler = require(ReplicatedStorage.Modules.Handlers.CameraHandler)
          end)
      end

      if cachedCameraHandler and cachedCameraHandler.currentRotation then
          -- The viewmodel correctly aligns if we steer currentRotation (X=pitch, Y=yaw)
          local dir = (targetPos - pos).Unit
          local targetPitch = math.asin(dir.Y)
          local targetYaw = math.atan2(-dir.X, -dir.Z)
          
          local currX = cachedCameraHandler.currentRotation.X or 0
          local currY = cachedCameraHandler.currentRotation.Y or 0
          
          local diff = targetYaw - currY
          while diff < -math.pi do diff = diff + math.pi * 2 end
          while diff > math.pi do diff = diff - math.pi * 2 end
          
          local newPitch = currX + (targetPitch - currX) * alpha
          local newYaw = currY + diff * alpha
          
          if typeof(cachedCameraHandler.currentRotation) == "Vector3" then
              cachedCameraHandler.currentRotation = Vector3.new(newPitch, newYaw, 0)
          elseif typeof(cachedCameraHandler.currentRotation) == "Vector2" then
              cachedCameraHandler.currentRotation = Vector2.new(newPitch, newYaw)
          else
              cachedCameraHandler.currentRotation.X = newPitch
              cachedCameraHandler.currentRotation.Y = newYaw
          end
      else
          -- Fallback if CameraHandler isn't found
          camera.CFrame = camera.CFrame:Lerp(goal, alpha)
      end
end

