local function getLocalEyePos(simulationState)
    if EyeOrigin and simulationState then
        local success, result = pcall(function() return EyeOrigin.getAuthoritative(simulationState) end)
        if success and typeof(result) == "Vector3" then return result end
    end
    local myChar = LocalPlayer.Character
    if myChar and myChar.PrimaryPart then
        return myChar.PrimaryPart.Position + Vector3.new(0, 1.5, 0)
    end
    local camera = Workspace.CurrentCamera
    return camera and camera.CFrame.Position or Vector3.zero
end

-- Spoof the Chickynoid command's view angles (server-authoritative hit validation).
-- Hooks the ClientChickynoid class so it survives respawns and is hit on every command.
task.spawn(function()
    while not STATE.IsUnloaded do
        pcall(function()
            if not cachedCameraHandler then
                cachedCameraHandler = require(ReplicatedStorage.Modules.Handlers.CameraHandler)
            end
              if cachedCameraHandler and not cachedCameraHandler._RBUpdateHooked then
                  cachedCameraHandler._RBUpdateHooked = true
                  local oldUpdate = cachedCameraHandler.update
                  local rbTPPartCache = {}
                  cachedCameraHandler.update = function(self, dt, ...)
                      local res = oldUpdate(self, dt, ...)
                      if STATE.ThirdPerson and STATE.ThirdPersonMode == "Classic" then
                          self._RBThirdPersonActive = true
                          local myChar2 = getLocalCharacter()
                          if myChar2 then
                              for _, v in ipairs(myChar2:GetDescendants()) do
                                  if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                                      v.LocalTransparencyModifier = 0
                                      if v.Transparency >= 1 then
                                          v.Transparency = 0
                                      end
                                      -- Also catch decals (like faces) if they were hidden
                                  elseif v:IsA("Decal") and v.Name == "face" then
                                    v.LocalTransparencyModifier = 0
                                    v.Transparency = 0
                                  end
                              end
                          end
                          if LocalPlayer.CameraMode ~= Enum.CameraMode.Classic then
                                LocalPlayer.CameraMode = Enum.CameraMode.Classic
                            end
                          -- Hide ViewModel
                          pcall(function()
                              local vm = require(game:GetService("ReplicatedStorage").Modules.WeaponECS.Render.ViewModel)
                              if vm and vm.getControllers and myChar2 then
                                  local controllers = vm.getControllers(myChar2)
                                  if controllers then
                                      for _, ctrl in pairs(controllers) do
                                          if ctrl.setTransparency then ctrl:setTransparency(1) end
                                      end
                                  end
                              end
                              local render = require(game:GetService("ReplicatedStorage").Modules.WeaponECS.Render)
                              if render and render.viewModelController and render.viewModelController.setTransparency then
                                  render.viewModelController:setTransparency(1)
                              end
                          end)
                      elseif self._RBThirdPersonActive then
                          -- Third Person disabled -> restore the original first-person state
                          self._RBThirdPersonActive = false
                          local myChar2 = getLocalCharacter()
                          if myChar2 then
                              for _, v in ipairs(myChar2:GetDescendants()) do
                                  if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                                      v.LocalTransparencyModifier = 1
                                      if rbTPPartCache[v] ~= nil then
                                          v.Transparency = rbTPPartCache[v]
                                      end
                                  end
                              end
                          end
                          table.clear(rbTPPartCache)
                          if LocalPlayer.CameraMode ~= Enum.CameraMode.LockFirstPerson then
                              LocalPlayer.CameraMode = Enum.CameraMode.LockFirstPerson
                          end
                          -- Restore ViewModel visibility
                          pcall(function()
                              local vm = require(game:GetService("ReplicatedStorage").Modules.WeaponECS.Render.ViewModel)
                              if vm and vm.getControllers and myChar2 then
                                  local controllers = vm.getControllers(myChar2)
                                  if controllers then
                                      for _, ctrl in pairs(controllers) do
                                          if ctrl.setTransparency then ctrl:setTransparency(0) end
                                      end
                                  end
                              end
                              local render = require(game:GetService("ReplicatedStorage").Modules.WeaponECS.Render)
                              if render and render.viewModelController and render.viewModelController.setTransparency then
                                  render.viewModelController:setTransparency(0)
                              end
                          end)
                      end
                      return res
                  end
              end            local ClientModule = require(ReplicatedFirst.Packages.Chickynoid.Client.ClientModule)
            local lc = ClientModule and ClientModule.localChickynoid

            if lc then
                local class = getmetatable(lc)
                if class and rawget(class, "_RBHbHooked") ~= true then
                    rawset(class, "_RBHbHooked", true)
                    local origHb = class.Heartbeat
                    class.Heartbeat = function(self, cmd, ...)
                        if not STATE.IsUnloaded and type(cmd) == "table" and STATE.MasterSwitch then
                            local isShooting = game:GetService("UserInputService"):IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or STATE.TriggerBotFiring
                            local hasAimLock = STATE.Aimbot and IsAiming and STATE.CurrentAimTarget
                            
                            if hasAimLock then
                                local look = Workspace.CurrentCamera.CFrame.LookVector
                                cmd.yaw = math.atan2(-look.X, -look.Z)
                                cmd.pitch = math.asin(math.clamp(-look.Y, -1, 1))
                            end
                            
                            if STATE.Spinbot then
                                if not isShooting then
                                    cmd.yaw = (tick() * (STATE.SpinbotSpeed or 15)) % (math.pi * 2)
                                elseif not hasAimLock then
                                    local look = Workspace.CurrentCamera.CFrame.LookVector
                                    cmd.yaw = math.atan2(-look.X, -look.Z)
                                    cmd.pitch = math.asin(math.clamp(-look.Y, -1, 1))
                                end
                            end
                        end
                        return origHb(self, cmd, ...)
                    end
                end
            end
        end)
        task.wait(1)
    end
end)

