local cachedGameplayHandler = nil
local function isEnemy(player)
    if not STATE.TeamCheck then return true end
    if not player then return true end
    if player == LocalPlayer then return false end

    if not cachedGameplayHandler then
        pcall(function() cachedGameplayHandler = require(ReplicatedStorage.Modules.Handlers.GameplayHandler) end)
    end

    if cachedGameplayHandler and cachedGameplayHandler.GetPlayerDuelId and cachedGameplayHandler.DuelData then
        local success, result = pcall(function()
            local myDuel = cachedGameplayHandler:GetPlayerDuelId(LocalPlayer)
            local theirDuel = cachedGameplayHandler:GetPlayerDuelId(player)
            
            if myDuel ~= theirDuel then
                return false
            end
            if not myDuel then return nil end
            
            local duelData = cachedGameplayHandler.DuelData[myDuel]
            if duelData and duelData.teams then
                local myTeam = nil
                local theirTeam = nil
                for teamIndex, teamData in pairs(duelData.teams) do
                    for _, teamPlayer in pairs(teamData.players or {}) do
                        if teamPlayer == LocalPlayer or (typeof(teamPlayer) == "Instance" and teamPlayer.Name == LocalPlayer.Name) then
                            myTeam = teamIndex
                        end
                        if teamPlayer == player or (typeof(teamPlayer) == "Instance" and teamPlayer.Name == player.Name) then
                            theirTeam = teamIndex
                        end
                    end
                end
                if myTeam and theirTeam then
                    return myTeam ~= theirTeam
                end
                if duelData.mode == "FFA" or duelData.mode == "GunGame" then
                    return true
                end
            end
            return nil
        end)
        if success and result ~= nil then
            return result
        end
    end

    if LocalPlayer.Team ~= nil and player.Team ~= LocalPlayer.Team then return true end
    if LocalPlayer.Team == nil then return true end
    return false
end

