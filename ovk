-- FOV gradient fill. Uses Triangle drawings to make a conic (spinnable) gradient.
-- Falls back to a flat filled circle if the executor lacks Triangle support.
local FOV_FILL_SIDES = 120
local FOV_FILL_TRIS = {}
local FOV_TRI_SUPPORTED = false
do
    local ok, tri = pcall(function() return Drawing.new("Triangle") end)
    if ok and tri then
        FOV_TRI_SUPPORTED = true
        pcall(function() tri:Remove() end)
        for i = 1, FOV_FILL_SIDES do
            FOV_FILL_TRIS[i] = newDrawing("Triangle", { Filled = true, Thickness = 0, Transparency = 0.35, Visible = false, ZIndex = 1 })
        end
    end
end

