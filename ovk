local function rename(descendant)
    pcall(function()
        if descendant:IsA("TextLabel") or descendant:IsA("TextBox") or descendant:IsA("TextButton") then
            local text = descendant.Text or ""

            if type(text) ~= "string" or text == "" then
                pcall(function() text = descendant.ContentText end)
            end

            if type(text) == "string" and text ~= "" then
                if STATE.NameSpoofer and STATE.SpoofedName ~= "" then
                    local me = LocalPlayer
                    local changed = false
                    local fixedText = text
                    
                    if me.Name and #me.Name >= 3 and string.find(string.lower(text), string.lower(me.Name), 1, true) then
                        fixedText = string.gsub(fixedText, me.Name, STATE.SpoofedName)
                        changed = true
                    end
                    if me.DisplayName and #me.DisplayName >= 3 and string.find(string.lower(text), string.lower(me.DisplayName), 1, true) then
                        fixedText = string.gsub(fixedText, me.DisplayName, STATE.SpoofedName)
                        changed = true
                    end
                    
                    if changed then
                        pcall(function() 
                            descendant.Text = fixedText 
                        end)
                        text = fixedText
                    end
                end

                if STATE.CensorText and text ~= STATE.CensorRenameText then
                    local lowerText = string.lower(text)
                    for _, p in ipairs(Players:GetPlayers()) do
                        if typeof(p.Name) == "string" and #p.Name >= 3 then
                            if string.find(lowerText, string.lower(p.Name), 1, true) then
                                pcall(function() descendant.Text = STATE.CensorRenameText end)
                                break
                            end
                        end
                        if typeof(p.DisplayName) == "string" and #p.DisplayName >= 3 then
                            if string.find(lowerText, string.lower(p.DisplayName), 1, true) then
                                pcall(function() descendant.Text = STATE.CensorRenameText end)
                                break
                            end
                        end
                    end
                end
            end
        elseif descendant:IsA("Humanoid") then
            local text = descendant.DisplayName or ""
            if type(text) == "string" and text ~= "" and text ~= STATE.CensorRenameText then
                local lowerText = string.lower(text)
                for _, p in ipairs(Players:GetPlayers()) do
                    if typeof(p.Name) == "string" and #p.Name >= 3 then
                        if string.find(lowerText, string.lower(p.Name), 1, true) then
                            pcall(function() descendant.DisplayName = STATE.CensorRenameText end)
                            break
                        end
                    end
                    if typeof(p.DisplayName) == "string" and #p.DisplayName >= 3 then
                        if string.find(lowerText, string.lower(p.DisplayName), 1, true) then
                            pcall(function() descendant.DisplayName = STATE.CensorRenameText end)
                            break
                        end
                    end
                end
            end
        end
    end)
end

local function censor_players(descendant)
    if not STATE.CensorAvatars then return end
    pcall(function()
        if descendant:IsA("Accessory") or descendant:IsA("Shirt") or descendant:IsA("Pants") or descendant:IsA("ShirtGraphic") or descendant:IsA("BodyColors") then
            descendant:Destroy()
        elseif descendant:IsA("BasePart") and descendant.Parent and descendant.Parent:FindFirstChild("Humanoid") then
            descendant.Color = Color3.new(0, 0, 0)
        end
    end)
end

local function hookPropertyChanged(guiObj)
    if not STATE.CensorListeners then return end
    if guiObj:IsA("TextLabel") or guiObj:IsA("TextBox") or guiObj:IsA("TextButton") then
        if guiObj:GetAttribute("RBCensorHooked") then return end
        guiObj:SetAttribute("RBCensorHooked", true)
        guiObj:GetPropertyChangedSignal("Text"):Connect(function()
            if STATE.CensorText then
                rename(guiObj)
            end
        end)
        guiObj:GetPropertyChangedSignal("ContentText"):Connect(function()
            if STATE.CensorText then
                rename(guiObj)
            end
        end)
    elseif guiObj:IsA("Humanoid") then
        if guiObj:GetAttribute("RBCensorHooked") then return end
        guiObj:SetAttribute("RBCensorHooked", true)
        guiObj:GetPropertyChangedSignal("DisplayName"):Connect(function()
            if STATE.CensorText then
                rename(guiObj)
            end
        end)
    end
end

local listenersConnected = false

local function run_check()
    if not STATE.CensorText and not STATE.NameSpoofer then return end
    
    pcall(function()
        local myChar = getLocalCharacter()
        if myChar then
            for _, descendant in ipairs(myChar:GetDescendants()) do
                rename(descendant)
                censor_players(descendant)
                hookPropertyChanged(descendant)
            end
        end
    end)

    local wsDescendants = Workspace:GetDescendants()
    for i, descendant in ipairs(wsDescendants) do
        if i % 1000 == 0 then task.wait() end
        if not STATE.CensorListeners then return end
        rename(descendant)
        censor_players(descendant)
        hookPropertyChanged(descendant)
    end

    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if playerGui then
        local pgDescendants = playerGui:GetDescendants()
        for i, descendant in ipairs(pgDescendants) do
            if i % 1000 == 0 then task.wait() end
            if not STATE.CensorListeners then return end
            rename(descendant)
            hookPropertyChanged(descendant)
        end
    end

    pcall(function()
        if CoreGuiService then
            local cgDescendants = CoreGuiService:GetDescendants()
            for i, descendant in ipairs(cgDescendants) do
                if i % 1000 == 0 then task.wait() end
                if not STATE.CensorListeners then return end
                rename(descendant)
                hookPropertyChanged(descendant)
            end
        end
    end)
end

local function attach_listeners()
    if listenersConnected then return end
    listenersConnected = true
    
    Workspace.DescendantAdded:Connect(function(descendant)
        if STATE.CensorListeners then
            rename(descendant)
            censor_players(descendant)
            hookPropertyChanged(descendant)
        end
    end)
    
    local playerGui = LocalPlayer:WaitForChild("PlayerGui", 5)
    if playerGui then
        playerGui.DescendantAdded:Connect(function(descendant)
            if STATE.CensorListeners then
                rename(descendant)
                hookPropertyChanged(descendant)
            end
        end)
    end
    
    pcall(function()
        if CoreGuiService then
            CoreGuiService.DescendantAdded:Connect(function(descendant)
                if STATE.CensorListeners then
                    rename(descendant)
                    hookPropertyChanged(descendant)
                end
            end)
        end
    end)
end

