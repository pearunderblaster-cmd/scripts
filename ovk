local HttpService = game:GetService("HttpService")
local lastStateJSON = ""

local function getConfigList()
    local files = {}
    pcall(function()
        if isfolder and not isfolder("OverkillConfigs") then
            makefolder("OverkillConfigs")
        end
        if listfiles then
            for _, file in ipairs(listfiles("OverkillConfigs")) do
                local name = file:match("([^/\\]+)%.json$")
                -- Skip the legacy library-choice file: older versions stored it in this
                -- folder, and it must never appear as a selectable script config.
                if name and name ~= "LibraryChoice" then
                    table.insert(files, name)
                end
            end
        end
    end)
    if #files == 0 then table.insert(files, "Default") end
    return files
end

local CONFIG_SKIP_KEYS = { ConfigSelection = true, ConfigNameInput = true, IsUnloaded = true }

local function serializeState()
    local toSave = {}
    for k, v in pairs(STATE) do
        if not CONFIG_SKIP_KEYS[k] then
            if type(v) == "number" or type(v) == "string" or type(v) == "boolean" then
                toSave[k] = v
            elseif typeof(v) == "Color3" then
                toSave[k] = { _type = "Color3", R = v.R, G = v.G, B = v.B }
            end
        end
    end
    return toSave
end

local function saveConfig(force)
    if pcall(function() return writefile end) and writefile then
        local toSave = serializeState()
        
        local validName = (STATE.ConfigNameInput ~= "" and STATE.ConfigNameInput ~= nil and STATE.ConfigNameInput) or "Default"
        local filePath = "OverkillConfigs/" .. validName .. ".json"
        
        local currentJSON = ""
        pcall(function() currentJSON = HttpService:JSONEncode(toSave) end)
        
        if currentJSON ~= "" then
            local dedupKey = validName .. "\0" .. currentJSON
            if force or dedupKey ~= lastStateJSON then
                lastStateJSON = dedupKey
                pcall(function()
                    if isfolder and not isfolder("OverkillConfigs") then
                        makefolder("OverkillConfigs")
                    end
                    writefile(filePath, currentJSON)
                end)
            end
        end
    end
end

local function loadConfig(configName)
    local targetName = configName or STATE.ConfigSelection or "Default"
    if type(targetName) == "table" then
        for k, v in pairs(targetName) do if v then targetName = k break end end
    end
    targetName = tostring(targetName)
    local filePath = "OverkillConfigs/" .. targetName .. ".json"
    
    if pcall(function() return readfile and isfile end) and readfile and isfile then
        local success = pcall(function()
            if not isfile(filePath) then
                if isfile("OverkillConfig.json") and targetName == "Default" then
                    filePath = "OverkillConfig.json"
                else
                    return
                end
            end
            if isfile(filePath) then
                local decoded = HttpService:JSONDecode(readfile(filePath))
                for k, v in pairs(decoded) do
                    if STATE[k] ~= nil and not CONFIG_SKIP_KEYS[k] then
                        if type(v) == "table" and v._type == "Color3" then
                            STATE[k] = Color3.new(v.R, v.G, v.B)
                        else
                            STATE[k] = v
                        end
                    end
                end
                -- Make the loaded config active so auto-save targets the same file,
                -- and refresh the dedup key so auto-save reflects the loaded state.
                STATE.ConfigNameInput = targetName
                local newJSON = ""
                pcall(function() newJSON = HttpService:JSONEncode(serializeState()) end)
                lastStateJSON = targetName .. "\0" .. newJSON
            end
        end)
    end
end
