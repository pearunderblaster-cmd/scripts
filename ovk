-- ─── Remove Velocity Cap ────────────────────────────────────────────────────
-- Two independent movement guardrails limit the player's speed. This feature overrides BOTH:
--   1. MathUtils.CapVelocity -> hard-clamps a velocity vector to a maximum magnitude (used by
--                               Simulation.CrashLand on landing). We make it a passthrough.
--   2. Simulation constants  -> maxSpeed/airSpeed/etc. feed GroundAccelerate's speed target.
--                               We scale them on the LOCAL movement simulation each frame.
local velocityCapEnforcerConn = nil
local vc_mathUtils = nil
local vc_trackedSim = nil
local vc_originalConsts = nil
local vc_applied = false
local VC_CAP_KEYS = { "maxSpeed", "airSpeed", "pushSpeed", "normalizedWalkSpeed", "normalizedRunSpeed" }

-- Module 1: neutralise the hard velocity clamp.
pcall(function()
    vc_mathUtils = require(ReplicatedFirst.Packages.Chickynoid.Shared.Simulation.MathUtils)
    if vc_mathUtils and vc_mathUtils.CapVelocity then
        getgenv().vc_capVelocity = getgenv().vc_capVelocity or vc_mathUtils.CapVelocity
        local originalCap = getgenv().vc_capVelocity
        vc_mathUtils.CapVelocity = function(selfMU, vel, maxSpeed, ...)
            if not STATE.IsUnloaded and STATE.RemoveVelocityCap then
                return vel
            end
            return originalCap(selfMU, vel, maxSpeed, ...)
        end
    end
end)

-- Module 2: raise the local movement simulation's speed constants while enabled, and restore
-- the untouched defaults the moment the toggle is turned off (or the character respawns).
velocityCapEnforcerConn = RunService.Heartbeat:Connect(function()
    if STATE.IsUnloaded then return end
    local sim = getLocalSimulation()
    if not sim or not sim.constants then return end

    if sim ~= vc_trackedSim then
        vc_trackedSim = sim
        vc_originalConsts = {}
        for _, key in ipairs(VC_CAP_KEYS) do vc_originalConsts[key] = sim.constants[key] end
        vc_applied = false
    end

    if STATE.RemoveVelocityCap then
        local mult = math.max(1, STATE.VelocityCapMultiplier or 1)
        for _, key in ipairs(VC_CAP_KEYS) do
            local base = vc_originalConsts[key]
            if base ~= nil then
                local target = base * mult
                if sim.constants[key] ~= target then sim.constants[key] = target end
            end
        end
        vc_applied = true
    elseif vc_applied then
        for _, key in ipairs(VC_CAP_KEYS) do
            if vc_originalConsts[key] ~= nil then sim.constants[key] = vc_originalConsts[key] end
        end
        vc_applied = false
    end
end)

