-- the "Saved Configs" list (getConfigList only scans OverkillConfigs). Older versions kept
-- it inside that folder, so we still read that legacy path for backward compatibility and
-- migrate it out on the next save.
local choiceConfigPath = "OverkillLibraryChoice.json"
local legacyChoiceConfigPath = "OverkillConfigs/LibraryChoice.json"
local libChoiceData = { Choice = "Linoria", DontAsk = false }

pcall(function()
    local path
    if isfile and isfile(choiceConfigPath) then
        path = choiceConfigPath
    elseif isfile and isfile(legacyChoiceConfigPath) then
        path = legacyChoiceConfigPath
    end
    if path then
        local saved = HttpService:JSONDecode(readfile(path))
        if saved.Choice then libChoiceData.Choice = saved.Choice end
        if saved.DontAsk ~= nil then libChoiceData.DontAsk = saved.DontAsk end
    end
end)

local function saveChoice(choice, dontAsk)
    pcall(function()
        writefile(choiceConfigPath, HttpService:JSONEncode({ Choice = choice, DontAsk = dontAsk }))
        -- Migrate away from the legacy in-folder location so it stops polluting the config list.
        if isfile and isfile(legacyChoiceConfigPath) and delfile then
            pcall(delfile, legacyChoiceConfigPath)
        end
    end)
end

