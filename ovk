local mobileToggleGui = nil
local function createMobileToggle()
    local sg = Instance.new("ScreenGui")
    sg.Name = generateRandomString(10)
    sg.ResetOnSpawn = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Global
    sg.Enabled = STATE.MobileToggleGui or (UserInputService.TouchEnabled and not UserInputService.MouseEnabled)
    STATE.MobileToggleGui = sg.Enabled
    
    local parented = false
    pcall(function()
        if typeof(gethui) == "function" then sg.Parent = gethui(); parented = true
        elseif CoreGuiService then sg.Parent = CoreGuiService; parented = true end
    end)
    if not parented then
        local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if pg then sg.Parent = pg end
    end

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 45, 0, 45)
    btn.Position = UDim2.new(0.5, -22, 0, 15)
    btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    btn.BackgroundTransparency = 0.3
    btn.BorderColor3 = Color3.fromRGB(80, 140, 255)
    btn.BorderSizePixel = 2
    btn.Text = "UI"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 16
    btn.Font = Enum.Font.Code
    btn.AutoButtonColor = false
    btn.Active = true
    btn.Parent = sg

    -- Toggle the active UI library's menu. Every adapter exposes Library:Toggle()
    -- (Linoria/Obsidian natively, Fluent/Atlanta/Mentality via the adapter), so this
    -- single call shows/hides the menu no matter which library was chosen at launch.
    local function toggleMenu()
        if Library and type(Library.Toggle) == "function" then
            pcall(function() Library:Toggle() end)
        end
    end

    -- Draggable, but a clean tap (no meaningful drag) toggles the menu. We track the
    -- pointer travel between press and release so dragging to reposition the button
    -- doesn't also open/close the UI.
    local dragging, dragInput, dragStart, startPos
    local moved = 0

    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            moved = 0
            dragStart = input.Position
            startPos = btn.Position
        end
    end)

    btn.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            moved = math.max(moved, math.abs(delta.X) + math.abs(delta.Y))
            btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    btn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if dragging and moved < 6 then
                toggleMenu()
            end
            dragging = false
        end
    end)

    return sg
end
