})

local function renderFOVFill(center, radius)
    local on = STATE.MasterSwitch and STATE.Aimbot and STATE.AimFOVFilled and STATE.AimShowFOV
    if not FOV_TRI_SUPPORTED then
        -- Fallback: flat filled circle (no gradient/spin available)
        if FOVCircle then
            FOVCircle.Filled = on
            FOVCircle.Transparency = on and 0.25 or 0.7
        end
        return
    end
    if FOVCircle then FOVCircle.Filled = false end
    if not on then
        for _, tri in ipairs(FOV_FILL_TRIS) do tri.Visible = false end
        return
    end
    local c1 = STATE.AimFOVGrad1
    local c2 = STATE.AimFOVGrad2
    local spin = STATE.AimFOVSpin and (tick() * 1.2) or 0
    local n = #FOV_FILL_TRIS
    local trans = 0.25
    for i = 1, n do
        local a0 = (i - 1) / n * math.pi * 2
        local a1 = i / n * math.pi * 2
        local tri = FOV_FILL_TRIS[i]
        tri.PointA = center
        tri.PointB = center + Vector2.new(math.cos(a0) * radius, math.sin(a0) * radius)
        tri.PointC = center + Vector2.new(math.cos(a1) * radius, math.sin(a1) * radius)
        local mid = (a0 + a1) / 2
        local t = (1 + math.cos(mid - spin)) / 2
        tri.Color = c1:Lerp(c2, t)
        tri.Transparency = trans
        tri.Visible = true
    end
end

