    Library.ToggleKeybind = nil
    Library.Options = Fluent.Options

    function Library:Notify(msg, dur)
        pcall(function()
            Fluent:Notify({ Title = "Overkill", Content = tostring(msg), Duration = dur or 5 })
        end)
    end

    function Library:Toggle()
        pcall(function()
            if Fluent.GUI then Fluent.GUI.Enabled = not Fluent.GUI.Enabled end
        end)
    end

    function Library:Unload()
        Library.Unloaded = true
        pcall(function() Fluent:Destroy() end)
    end

    local function adaptColorPicker(container, id, cfg)
        local cp = container:AddColorpicker(id, {
            Title   = cfg.Title or cfg.Text or tostring(id),
            Default = cfg.Default or Color3.new(1, 1, 1),
        })
        if cfg.Callback then cp:OnChanged(function() cfg.Callback(cp.Value) end) end
        return cp
    end

    local function adaptKeyPicker(container, id, cfg)
        return container:AddKeybind(id, {
            Title   = cfg.Text or "Keybind",
            Mode    = "Toggle",
            Default = cfg.Default or "K",
        })
    end

    local function adaptLabel(container, text)
        local label = {}
        local para = container:AddParagraph({ Title = tostring(text or ""), Content = "" })
        function label:SetText(t)
            if para and para.SetTitle then pcall(function() para:SetTitle(tostring(t)) end) end
        end
        function label:AddColorPicker(id, cfg)
            if para and para.Destroy then pcall(function() para:Destroy() end) end
            para = nil
            return adaptColorPicker(container, id, cfg)
        end
        function label:AddKeyPicker(id, cfg)
            if para and para.Destroy then pcall(function() para:Destroy() end) end
            para = nil
            return adaptKeyPicker(container, id, cfg)
        end
        return label
    end

    local function makeGroupbox(section)
        local gb = {}
        function gb:AddToggle(id, cfg)
            local t = section:AddToggle(id, {
                Title       = cfg.Text or tostring(id),
                Default     = cfg.Default and true or false,
                Description = cfg.Tooltip,
            })
            if cfg.Callback then t:OnChanged(function() cfg.Callback(t.Value) end) end
           
            return t
        end
        function gb:AddSlider(id, cfg)
            local s = section:AddSlider(id, {
                Title    = cfg.Text or tostring(id),
                Default  = cfg.Default or cfg.Min or 0,
                Min      = cfg.Min or 0,
                Max      = cfg.Max or 100,
                Rounding = cfg.Rounding or 0,
            })
            if cfg.Callback then s:OnChanged(function() cfg.Callback(s.Value) end) end
            return s
        end
        function gb:AddDropdown(id, cfg)
            local d = section:AddDropdown(id, {
                Title   = cfg.Text or tostring(id),
                Values  = cfg.Values or {},
                Default = cfg.Default,
                Multi   = cfg.Multi and true or false,
            })
            if cfg.Callback then d:OnChanged(function() cfg.Callback(d.Value) end) end
            return d
        end
        function gb:AddLabel(text)
            return adaptLabel(section, text)
        end
        function gb:AddInput(id, cfg)
            local inp = section:AddInput(id, {
                Title       = cfg.Text or tostring(id),
                Default     = cfg.Default,
                Placeholder = cfg.Placeholder,
                Numeric     = cfg.Numeric and true or false,
                Finished    = cfg.Finished and true or false,
            })
            if cfg.Callback then inp:OnChanged(function() cfg.Callback(inp.Value) end) end
            return inp
        end
        function gb:AddButton(cfg)
            local func = cfg.Func or cfg.Callback or function() end
            if cfg.DoubleClick then
                local original, lastClick = func, 0
                func = function()
                    local now = os.clock()
                    if now - lastClick <= 0.6 then
                        lastClick = 0
                        original()
                    else
                        lastClick = now
                    end
                end
            end
            section:AddButton({ Title = cfg.Text or "Button", Description = cfg.Tooltip, Callback = func })
            return {}
        end
        function gb:AddDivider() end
        return gb
    end

    Window = {}
    function Window:AddTab(name)
        local t = fluentWindow:AddTab({ Title = tostring(name) })
        local tab = {}
        function tab:AddLeftGroupbox(title)  return makeGroupbox(t) end
        function tab:AddRightGroupbox(title) return makeGroupbox(t) end
        return tab
    end
end

