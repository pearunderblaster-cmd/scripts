local wrapNames = {}
local skinNames = {"None"}
local charmNames = {"None"}
local finisherNames = {"None"}
local skinMap = {}

pcall(function()
    local dir = require(ReplicatedStorage:WaitForChild("Milk"):WaitForChild("Directory"))
    if dir and dir.Wraps then
        for wrapName, _ in pairs(dir.Wraps) do
            table.insert(wrapNames, wrapName)
        end
        table.sort(wrapNames)
    end
    if dir and dir.Items and dir.Items.all then
        for weapId, wData in pairs(dir.Items.all) do
            if wData.skins then
                for skinId, _ in pairs(wData.skins) do
                    table.insert(skinNames, skinId)
                    skinMap[skinId] = weapId
                end
            end
        end
    end
    if dir and dir.Charms then
        for charmId, _ in pairs(dir.Charms) do
            table.insert(charmNames, charmId)
        end
    end
    if dir and dir.Finishers then
        for finId, _ in pairs(dir.Finishers) do
            table.insert(finisherNames, finId)
        end
    end
    table.sort(skinNames)
    table.sort(charmNames)
    table.sort(finisherNames)
end)
if #wrapNames == 0 then table.insert(wrapNames, "None") end

local ItemResolverHookLoaded = false
local oldItemGetEquipped = nil
local dirGetHookLoaded = false
local levelHookLoaded = false
local dataHandlerHookLoaded = false

task.spawn(function()
    while task.wait(1) do
        if STATE.IsUnloaded then break end
        
        if not dataHandlerHookLoaded then
            pcall(function()
                local DataHandler = require(ReplicatedStorage.Modules.Handlers.DataHandler)
                if DataHandler and DataHandler.GetDataAsync and not DataHandler._RBHooked then
                    dataHandlerHookLoaded = true
                    DataHandler._RBHooked = true
                    local oldGetData = DataHandler.GetDataAsync
                    DataHandler.GetDataAsync = function(self, p2)
                        p2 = p2 or LocalPlayer
                        local res = oldGetData(self, p2)
                        if p2 == LocalPlayer and type(res) == "table" then
                            local mt = getmetatable(res)
                            if not mt or not mt.__RBSpoofed then
                                local proxy = setmetatable({}, {
                                    __RBSpoofed = true,
                                    __index = function(t, k)
                                        if STATE.LevelSpoofer and k == "XP" then
                                            local LevelHelper = require(ReplicatedStorage.Milk.Helpers.LevelHelper)
                                            if LevelHelper and LevelHelper.GetXPByLevel then
                                                return LevelHelper:GetXPByLevel(STATE.SpoofedLevel)
                                            end
                                        end
                                        if (STATE.WinRateSpoofer or STATE.StatsSpoofer) and k == "Stats" then
                                            local statsTable = rawget(res, k)
                                            if type(statsTable) == "table" then
                                                local newStats = {}
                                                for sk, sv in pairs(statsTable) do newStats[sk] = sv end
                                                
                                                if STATE.WinRateSpoofer then
                                                    local duels_played = statsTable.duels_played or 100
                                                    local fakeWins = math.floor(duels_played * (STATE.SpoofedWinRate / 100))
                                                    newStats.duels_won = fakeWins
                                                end
                                                
                                                if STATE.StatsSpoofer then
                                                    newStats.eliminations = STATE.SpoofedElims
                                                    newStats.deaths = STATE.SpoofedDeaths
                                                    newStats.assists = STATE.SpoofedAssists
                                                    newStats.damage_dealt = STATE.SpoofedDmgDealt
                                                end
                                                
                                                return newStats
                                            end
                                        end
                                        return res[k]
                                    end,
                                    __newindex = function(t, k, v)
                                        res[k] = v
                                    end
                                })
                                return proxy
                            end
                        end
                        return res
                    end
                end
            end)
        end

        if not levelHookLoaded then
            pcall(function()
                local LevelHelper = require(ReplicatedStorage.Milk.Helpers.LevelHelper)
                if LevelHelper and LevelHelper.GetLevelByXP and not LevelHelper._RBHooked then
                    levelHookLoaded = true
                    LevelHelper._RBHooked = true
                    local oldGetLvl = LevelHelper.GetLevelByXP
                    LevelHelper.GetLevelByXP = function(...)
                        if STATE.LevelSpoofer and STATE.SpoofedLevel then
                            return STATE.SpoofedLevel
                        end
                        return oldGetLvl(...)
                    end
                end
            end)
            pcall(function()
                local PlayerData = require(ReplicatedStorage.Modules.Handlers.PlayerHandler)
                if PlayerData and PlayerData.getWinRate and not PlayerData._RBHooked then
                    PlayerData._RBHooked = true
                    local oldWR = PlayerData.getWinRate
                    PlayerData.getWinRate = function(...)
                        if STATE.WinRateSpoofer and STATE.SpoofedWinRate then
                            return STATE.SpoofedWinRate
                        end
                        return oldWR(...)
                    end
                end
            end)
        end

        if not ItemResolverHookLoaded then
            pcall(function()
                local ItemResolver = require(ReplicatedStorage.Modules.WeaponECS.Resolve.ItemResolver)
                if ItemResolver and ItemResolver.getEquipped then
                    ItemResolverHookLoaded = true
                    oldItemGetEquipped = ItemResolver.getEquipped
                    
                    if not ItemResolver._RBEquippedHooked then
                        ItemResolver._RBEquippedHooked = true
                        ItemResolver.getEquipped = function(...)
                        local res = oldItemGetEquipped(...)
                        if type(res) == "table" and not STATE.IsUnloaded then
                            if STATE.SkinChanger and STATE.SkinSelection ~= "None" then
                                local targetWeap = res.rootID or res.weaponID or res.ID
                                if skinMap[STATE.SkinSelection] == targetWeap then
                                    res.skin = STATE.SkinSelection
                                end
                            end
                            if STATE.CharmChanger and STATE.CharmSelection ~= "None" then
                                res.charm = STATE.CharmSelection
                            end
                        end
                        return res
                    end
                end
		end
            end)
        end
        if not dirGetHookLoaded then
            pcall(function()
                local dir = require(ReplicatedStorage.Milk.Directory)
                if dir and dir.GetByData and not dir._RBHooked then
                    dirGetHookLoaded = true
                    dir._RBHooked = true
                    local oldGet = dir.GetByData
                    dir.GetByData = function(self, p2, p3, ...)
                        if not STATE.IsUnloaded and type(p3) == "table" then
                            local np3 = table.clone(p3)
                            local wId = np3.rootID or np3.ID
                            if p2 == "Items" and STATE.SkinChanger and STATE.SkinSelection ~= "None" and skinMap[STATE.SkinSelection] == wId then
                                np3.skin = STATE.SkinSelection
                            elseif p2 == "Charms" and STATE.CharmChanger and STATE.CharmSelection ~= "None" then
                                np3.ID = STATE.CharmSelection
                            elseif p2 == "Finishers" and STATE.FinisherChanger and STATE.FinisherSelection ~= "None" then
                                np3.ID = STATE.FinisherSelection
                            end
                            return oldGet(self, p2, np3, ...)
                        end
                        return oldGet(self, p2, p3, ...)
                    end
                end
            end)
        end
    end
end)

